msgctxt "mp/lobby/setup/settings.assignReinforcementsToPlayer"
msgid "Buyer gets units"
msgstr "Comprador recebe as unidades"

msgctxt "mp/lobby/setup/settings.assignReinforcementsToPlayer#hint"
msgid "If on, enables reinforcements to go to the player who buys the unit.\nIf off, reinforcements are distributed evenly to all players regardless of who buys the unit."
msgstr "Se ativado, os reforços vão para o jogador que compra a unidade.\nSe desativado, os reforços são distribuídos igualmente a todos os jogadores, independente de quem comprou."
