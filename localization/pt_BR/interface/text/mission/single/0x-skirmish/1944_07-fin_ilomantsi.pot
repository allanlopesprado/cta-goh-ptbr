msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/outro_completed"
msgid "Mission accomplished!"
msgstr "Missão cumprida!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/outro_failed"
msgid "Mission failure!"
msgstr "Missão fracassada!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/outro_failed_hq"
msgid "Mission failed! - The enemy captured your HQ!"
msgstr "Missão fracassada! - O inimigo capturou o seu QG!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/mission_hq"
msgid "You must hold your field HQ!"
msgstr "Você deve manter o seu QG de campo!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/mission_attack"
msgid "Hold the position at all costs!"
msgstr "Mantenha a posição a todo custo!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/flag_capture_status"
msgid "Your soldiers secured %1%/7 Soviet positions!"
msgstr "Seus soldados asseguraram %1%/7 posições soviéticas!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/narrator_start0"
msgid "Welcome to your North Karelia HQ, Major! This is the one place that has to remain in our control at all times."
msgstr "Bem-vindo ao seu QG da Carélia do Norte, Major! Este é o único lugar que deve permanecer sob nosso controle o tempo todo."

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/narrator_start1"
msgid "You will attack the enemy starting points to pre- empt his large- scale offensive. Break the enemy columns up in groups and destroy them!"
msgstr "Você atacará os pontos de partida do inimigo para antecipar sua ofensiva em grande escala. Divida as colunas inimigas em grupos e destrua-as!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/narrator_start2"
msgid "The enemy is bringing heavy units forward. Call the air force!"
msgstr "O inimigo está trazendo unidades pesadas à frente. Acione a força aérea!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/narrator_start3"
msgid "Keep the enemy on the defensive, while we get some reinforcements for you to deploy!"
msgstr "Mantenha o inimigo na defensiva, enquanto conseguimos alguns reforços para você implantar!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/allied_enemy_near_hq"
msgid "Asetoverit! Soviets are close to our Field HQ!"
msgstr "Asetoverit! Os soviéticos estão perto do nosso QG de campo!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/allied_enemy_plane"
msgid "Asetoverit! Soviet plane attacking!"
msgstr "Asetoverit! Avião soviético atacando!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/player_enemy_near_hq"
msgid "We must hold the command post! There can be no talk of retreat here!"
msgstr "Devemos manter nosso posto de comando! Nada de falar em retirada aqui!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/hq_bonus"
msgid "Major! Now you can request an airstrike."
msgstr "Major! Agora você pode solicitar um ataque aéreo."
