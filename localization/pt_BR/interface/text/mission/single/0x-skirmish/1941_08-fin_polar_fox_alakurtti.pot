msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/story"
msgid " Arctic front, the push for Murmansk. We have covered a lot of ground with our flanking attack. But the village ahead seems heavily defended. You need to attack immediately!\n\nGoals:\n - Destroy Soviet armor.\n - Take Alakurtti."
msgstr " Frente ártica, o avanço sobre Murmansk. Cobrimos muito terreno com nosso ataque de flanco. Mas a aldeia à frente parece fortemente defendida. Você precisa atacar imediatamente!\n\nObjetivos:\n - Destrua a blindagem soviética.\n - Tome Alakurtti."

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/place"
msgid "Alakurtti, Murmansk region"
msgstr "Alakurtti, região de Murmansk"

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/date"
msgid "July, 1941"
msgstr "Julho de 1941"

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/outro_start"
msgid ""
msgstr ""

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/outro_completed"
msgid "Mission accomplished!"
msgstr "Missão cumprida!"

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/outro_failed"
msgid "Mission failed!"
msgstr "Missão fracassada!"

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/outro_failed_hq"
msgid "Mission failed! - your HQ was taken!"
msgstr "Missão fracassada! - Seu QG foi tomado!"

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/mission_hq"
msgid "You have to hold your field HQ!"
msgstr "Você deve manter o seu QG de campo!"

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/mission_attack"
msgid "Attack the village of Alakurtti!"
msgstr "Ataque a aldeia de Alakurtti!"

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/flag_capture_status"
msgid "Your soldiers secured %1%/7 Soviet positions!"
msgstr "Seus soldados asseguraram %1%/7 posições soviéticas!"

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/narrator_start0"
msgid "Welcome to the Murmansk regional HQ, Major! It has to remain in our control at all times!"
msgstr "Bem-vindo ao QG regional de Murmansk, Major! Deve permanecer sob nosso controle o tempo todo!"

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/narrator_start1"
msgid "Comrade, you are tasked with performing a decisive push toward Murmansk! Take the village of Alakurtti!"
msgstr "Camarada, você está encarregado de realizar um avanço decisivo em direção a Murmansk! Tome a aldeia de Alakurtti!"

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/narrator_start2"
msgid "The Soviets may reinforce their lines with heavy armor. Make sure you move before they get here!"
msgstr "Os soviéticos podem reforçar suas linhas com blindagens pesadas. Certifique-se de se mover antes que cheguem!"

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/narrator_start3"
msgid "Begin securing the objectives, while we bring forward some reinforcements for you to deploy!"
msgstr "Comece a assegurar os objetivos, enquanto trazemos alguns reforços para você implantar!"

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/allied_enemy_near_hq"
msgid "Asetoverit! Soviets are close to our Field HQ!"
msgstr "Asetoverit! Os soviéticos estão perto do nosso QG de campo!"

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/player_enemy_near_hq"
msgid "We must hold the command post! There can be no talk of retreat here!"
msgstr "Devemos manter nosso posto de comando! Nada de falar em retirada aqui!"

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/hq_bonus"
msgid "Major! Now you can request an airstrike."
msgstr "Major! Agora você pode solicitar um ataque aéreo."
