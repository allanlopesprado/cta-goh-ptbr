msgstr "Recue para a posição inicial"

msgctxt "mission/single/02-ger/1943_07_petrovka/task_opt1"
msgid "Ensure the survival of your radio operator"
msgstr "Garanta a sobrevivência do seu operador de rádio"

msgctxt "mission/single/02-ger/1943_07_petrovka/task_opt2"
msgid "At least one tank must survive"
msgstr "Pelo menos um tanque deve sobreviver"

msgctxt "mission/single/02-ger/1943_07_petrovka/task_sec"
msgid "Secret Objective #1."
msgstr "Objetivo Secreto nº 1."

msgctxt "mission/single/02-ger/1943_07_petrovka/task_sec1"
msgid "Find a car and use it to get Rall back safely"
msgstr "Encontre um carro e use-o para levar Rall de volta em segurança"

