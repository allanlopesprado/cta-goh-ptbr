msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/name"
msgid "Battle of the Bulge [SKIRMISH]"
msgstr "Batalha das Ardenas [ESCARAMUÇA]"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/name_big"
msgid "Battle of the Bulge"
msgstr "Batalha das Ardenas"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/story"
msgid "The Battle of the Bulge\n\nAfter the initial battles, you are surrounded by Germans. Time for a breakout attempt!\n\nGoals:\n - Break the encirclement.\n - Close the front."
msgstr "A Batalha das Ardenas\n\nApós as batalhas iniciais, você está cercado por alemães. Hora de tentar uma ruptura!\n\nObjetivos:\n - Romper o cerco.\n - Fechar a frente."

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/place"
msgid "Region between Hotton and Bastogne"
msgstr "Região entre Hotton e Bastogne"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/date"
msgid "January, 1945"
msgstr "Janeiro de 1945"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/outro_start"
msgid ""
msgstr ""

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/outro_completed"
msgid "Well done! We'll drive them back to their starting point next!"
msgstr "Muito bem! Vamos expulsá-los de volta ao ponto de partida seguinte!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/outro_failed"
msgid "This is not the desired outcome. You need to regroup, and use different tactics!"
msgstr "Este não é o resultado desejado. Você precisa se reagrupar e usar táticas diferentes!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/outro_failed_hq"
msgid "We have been defeated at the Ardennes. With nothing to stop the Germans, they may get to Antwerp and cut our european armies in two!"
msgstr "Fomos derrotados nas Ardenas. Sem nada para deter os alemães, eles podem chegar a Antuérpia e cortar nossas forças europeias ao meio!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/mission_hq"
msgid "You must hold your field HQ!"
msgstr "Você deve manter o seu QG de campo!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/mission_attack"
msgid "Punch a hole in the enemy position and drive east!"
msgstr "Abra uma brecha na posição inimiga e avance para o leste!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/flag_capture_status"
msgid "Your soldiers secured %1%/7 German positions!"
msgstr "Seus soldados asseguraram %1%/7 posições alemãs!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/narrator_start0"
msgid "The German assault on the Ardennes has taken us by complete surprise! Lieutenant, This is your field HQ, as you know by now, we cannot afford to lose it!"
msgstr "O assalto alemão nas Ardenas nos surpreendeu completamente! Tenente — este é seu QG de campo; como você já sabe, não podemos nos dar ao luxo de perdê-lo!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/narrator_start1"
msgid "The Krauts hit us hard during Christmas, but our new year's resolution is to turn the tables on their offensive! Seize the initiative and drive the Nazis back to Germany!"
msgstr "Os alemães nos golpearam duro durante o Natal, mas nossa resolução de ano novo é virar o jogo contra a ofensiva deles! Tome a iniciativa e expulse os nazistas de volta à Alemanha!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/narrator_start2"
msgid "Expect heavy resistance from their well-trained and battle hardened troops."
msgstr "Espere resistência pesada de suas tropas bem treinadas e curtidas em batalha."

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/narrator_start3"
msgid "Begin the attack, Lieutenant! Show them what we're made of!"
msgstr "Inicie o ataque, Tenente! Mostre do que somos feitos!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/allied_enemy_near_hq"
msgid "Gentlemen! Germans are close to our Field HQ!"
msgstr "Senhores! Os alemães estão perto do nosso QG de campo!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/allied_enemy_plane"
msgid "Enemy plane!!!"
msgstr "Avião inimigo!!!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/allied_enemy_plane2"
msgid "German aircraft inbound!"
msgstr "Aeronave alemã se aproximando!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/player_enemy_near_hq"
msgid "We must hold our command post! You have your orders!"
msgstr "Devemos manter nosso posto de comando! Você tem suas ordens!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/hq_bonus"
msgid "Lieutenant! Now may now request an airstrike. The skies have cleared since the Krauts began their offensive, and now wse may resume our air supremacy!"
msgstr "Tenente! Agora pode solicitar um ataque aéreo. O céu clareou desde que os alemães iniciaram a ofensiva — agora podemos retomar nossa supremacia aérea!"
