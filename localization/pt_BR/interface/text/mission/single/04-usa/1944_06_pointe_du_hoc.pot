#, boost-format

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/arty_progress"
msgid "%1% out of 6 howitzer guns destroyed."
msgstr "%1% de 6 obuseiros destruídos."

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/date"
msgid "June 6th, 1944 · Pointe du Hoc, Normandy"
msgstr "6 de junho de 1944 · Pointe du Hoc, Normandia"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/defend"
msgid "German counterattack will arrive in:"
msgstr "Contra-ataque alemão chegará em:"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/maybe_hq_hold"
msgid "Fall back to the HQ to strenghten the perimeter"
msgstr "Recue ao QG para reforçar o perímetro"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/maybe_supplies"
msgid "Retrieve as many supply crates as you can"
msgstr "Recupere o máximo de caixas de suprimentos possível"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/mission_101"
msgid "Rescue two 101st airborne men stranded on west beach"
msgstr "Resgate dois homens da 101ª Aerotransportada presos na praia oeste"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/mission_artillery"
msgid "Find the guns and neutralize them"
msgstr "Encontre os canhões e neutralize-os"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/mission_battery"
msgid "Clear out German defenders and capture the battery"
msgstr "Elimine os defensores alemães e capture a bateria"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/mission_beach"
msgid "Climb the cliffs"
msgstr "Suba os penhascos"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/mission_defense"
msgid "Hold your ground until the relief forces arrive from Omaha Beach"
msgstr "Segure sua posição até a chegada das forças de alívio de Omaha Beach"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/mission_prep_defense"
msgid "Prepare a defensive perimeter for the night"
msgstr "Prepare um perímetro defensivo para a noite"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/name"
msgid "Day of Days"
msgstr "O Dia D"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/name_big"
msgid "Day of Days"
msgstr "O Dia D"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/00"
msgid "Welcome to France Lieutenant! The success of Operation Overlord depends on you!"
msgstr "Bem-vindo à França, Tenente! O sucesso da Operação Overlord depende de você!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/01"
msgid "Let's go, Rangers! Secure a foothold on the beach!"
msgstr "Vamos, Rangers! Estabeleçam uma posição na praia!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/02"
msgid "There are ladders all over the cliffs, use them to get to the top and assault those fortifications!"
msgstr "Há escadas por todo o penhasco — use-as para chegar ao topo e assaltar as fortificações!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/03"
msgid "You may also give the signal to USS Satterlee to bombard the Germans with naval battery fire."
msgstr "Você também pode dar o sinal ao USS Satterlee para bombardear os alemães com fogo naval."

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/04"
msgid "Shit! There's a Kraut 20mm still standing up there! Do something about it before it chews us up!"
msgstr "Merda! Ainda há uma canhão Kraut de 20 mm lá em cima! Façam alguma coisa antes que ela nos despedace!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/05"
msgid "You've now got a couple of light mortars to help you deal with the entrenched Germans."
msgstr "Agora você tem um par de morteiros leves para ajudar a lidar com os alemães entrincheirados."

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/06"
msgid "What the hell is this? Looks like Jerry's placed some dummy guns in these bunkers. They must've taken the real guns somewhere else!"
msgstr "O que diabos é isso? Parece que os Jerry's colocaram canhões falsos nesses bunkers. Devem ter levado os canhões reais para outro lugar!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/07"
msgid "Lieutenant, those guns can't have gotten far or intelligence would have picked it up. Lead a patrol over to the manor and find those guns!"
msgstr "Tenente — esses canhões não podem ter ido longe, senão a inteligência teria detectado. Leve uma patrulha até a mansão e encontre esses canhões!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/08"
msgid "We should expect the Germans to counterattack anytime. We need to set up a roadblock to keep them at bay."
msgstr "Devemos esperar o contra-ataque alemão a qualquer momento. Precisamos montar um bloqueio na estrada para mantê-los à distância."

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/09"
msgid "The first enemy attack has been successfully repelled. But we should be ready to defend this place into the night. Set up defences!"
msgstr "O primeiro ataque inimigo foi repelido com sucesso. Mas devemos estar prontos para defender este lugar até a noite. Montem defesas!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/10"
msgid "They're bringing in their own mortars and emplacements, watch out!"
msgstr "Eles estão trazendo seus próprios morteiros e posições — cuidado!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/11"
msgid "Alright, here comes the Cavalry!"
msgstr "Certo — aí vem a Cavalaria!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/12"
msgid "Rangers lead the way! The Liberation of Europe starts here! I'm proud of you, men!"
msgstr "Rangers abrem o caminho! A Libertação da Europa começa aqui! Tenho orgulho de vocês, homens!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/naval"
msgid "Colonel - You can now call in limited naval gun support from USS Satterlee!"
msgstr "Coronel — você pode agora solicitar apoio naval limitado do USS Satterlee!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/nogunshere"
msgid "You must advance at the garrison, search deeper inland. Find the guns and destroy them - good luck  Lieutenant!"
msgstr "Você deve avançar sobre a guarnição, procure mais profundamente no interior. Encontre os canhões e destrua-os — boa sorte, Tenente!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/narrator/p47"
msgid "Air support is on its way!"
msgstr "Apoio aéreo a caminho!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/naval_arty"
msgid "Naval Artillery"
msgstr "Artilharia Naval"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/naval_arty_hint"
msgid "Call in naval support from USS Satterlee"
msgstr "Solicitar apoio naval do USS Satterlee"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/outro_completed"
msgid "You have done an amazing job!\n\nWith the relief force from 29th Infantry division and the 743rd tank battalion in place, you can now have someone tend to your wounds and finally take a rest. Your efforts have saved many American lives, surely this will be remembered as one of the pivotal moments of this giant operation. The Liberation of Europe has begun!"
msgstr "Você fez um trabalho incrível!\n\nCom a força de alívio da 29ª Divisão de Infantaria e o 743º Batalhão de Tanques posicionados, você pode agora tratar seus ferimentos e finalmente descansar. Seus esforços salvaram muitas vidas americanas — certamente isso será lembrado como um dos momentos decisivos desta gigantesca operação. A Libertação da Europa começou!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/outro_failed"
msgid "We have failed!\n\nThis is quite a blow to our hopes of preventing casualties on Omaha and Utah beach. Surely, the Germans will start pounding the beaches with 155 mm shells very soon. There is nothing for it but to try again, failure is not an option. we must take out that battery!"
msgstr "Falhamos!\n\nEste é um golpe severo para nossas esperanças de evitar baixas nas praias de Omaha e Utah. Com certeza, os alemães começarão a bombardear as praias com projéteis de 155 mm muito em breve. Não há outra saída senão tentar novamente — o fracasso não é uma opção. Temos que neutralizar aquela bateria!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/place"
msgid "2nd Ranger Battalion"
msgstr "2º Batalhão Ranger"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/player/firstgundestroyed"
msgid "First gun destroyed!"
msgstr "Primeiro canhão destruído!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/player/gundestroyed"
msgid "Another one out of service!"
msgstr "Mais um fora de serviço!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/player/gundestroyed_alt"
msgid "Scratch another Kraut artillery!"
msgstr "Mais uma artilharia Kraut eliminada!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/player/nogunshere"
msgid "We have cleared the battery but the guns were wooden dummies."
msgstr "Limpamos a bateria, mas os canhões eram réplicas de madeira."

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/situation2"
msgid "D day, 21:30h"
msgstr "Dia D, 21h30"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/situation3"
msgid "Clear the remaining Germans off the beachhead!"
msgstr "Elimine os alemães restantes da cabeça de praia!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/skip"
msgid "Skip preparation phase"
msgstr "Pular fase de preparação"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/story"
msgid " “Operation Overlord” has begun! The largest armada of warships ever to have been assembled is crossing the English Channel towards France. Careful planning and reconnaissance has shown that it will be essential to take out specific parts of the “Atlantic wall” just before the beaches are stormed by the allies. One of them is the German battery at Pointe du Hoc. It is up to the 2nd Ranger battalion to scale Pointe du Hoc and silence the battery.\n\n In this mission, you will land on the small beach and fight your way to the top. Once at the top, you must drive the defenders away and find the battery. You will get support from USS Satterlee and the US air force if needed. This is where the liberation of Europe starts.\n\nGood luck!"
msgstr " A Operação Overlord começou! A maior armada de navios de guerra já reunida está cruzando o Canal da Mancha em direção à França. Um planejamento cuidadoso e reconhecimento mostraram que será essencial neutralizar partes específicas do Muro do Atlântico logo antes de as praias serem assaltadas pelos Aliados. Uma delas é a bateria alemã em Pointe du Hoc. Cabe ao 2º Batalhão Ranger escalar Pointe du Hoc e silenciar a bateria.\n\n Nesta missão, você desembarcará na pequena praia e abrirá caminho até o topo. Uma vez no alto, você deve expulsar os defensores e encontrar a bateria. Receberá apoio do USS Satterlee e da Força Aérea dos EUA, se necessário. É aqui que começa a libertação da Europa.\n\nBoa sorte!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/timer"
msgid "Expected German counter-attack:"
msgstr "Contra-ataque alemão esperado:"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/timer2"
msgid "Set up defenses around the manor:"
msgstr "Monte defesas ao redor da mansão:"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/timer3"
msgid "Defend the manor!"
msgstr "Defenda a mansão!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/00"
msgid "Looks like Baker Company landed too close to the machine guns on the cliffs. Destroy the MGs so that they can begin their assault!"
msgstr "Parece que a Companhia Baker desembarcou perto demais das metralhadoras no penhasco. Destrua as metralhadoras para que possam iniciar o assalto!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/01"
msgid "Good work, men! Machine guns are down. Baker Company will conduct their assault now!"
msgstr "Bom trabalho, homens! As metralhadoras foram neutralizadas. A Companhia Baker conduzirá seu assalto agora!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/02"
msgid "That Flak gun won't be bothering us anymore!"
msgstr "Aquele canhão antiaéreo não nos incomodará mais!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/03"
msgid "They are falling back! The Cliffs are now in our control!"
msgstr "Eles estão recuando! Os penhascos estão agora sob nosso controle!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/04"
msgid "Baker Company is getting hammered over there! They won't last much longer without some help. We need to knock out those Kraut mortars and AA guns."
msgstr "A Companhia Baker está sendo massacrada lá! Não resistirão por muito mais tempo sem ajuda. Precisamos neutralizar aqueles morteiros e canhões antiaéreos Kraut."

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/05"
msgid "B Company is getting chewed up! Support them from the flank!"
msgstr "A Companhia B está sendo dizimada! Apoie-os pelo flanco!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/06"
msgid "All guns have been destroyed! Excellent work, men!"
msgstr "Todos os canhões foram destruídos! Excelente trabalho, homens!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/07"
msgid "Well done. This Kraut gun will definitely come in handy."
msgstr "Muito bem. Este canhão Kraut certamente será útil."

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/08"
msgid "We're expecting a Jerry counter-attack any moment now. Dig in and use whatever you can to hold the line."
msgstr "Esperamos um contra-ataque Jerry a qualquer momento. Entrincheirem-se e usem o que puderem para manter a linha."

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/09"
msgid "Move your asses, get off the beach! Go!"
msgstr "Movam-se, saiam da praia! Vai!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/10"
msgid "You're easy targets for those Kraut MGs! Get away from the cliff! Move, move!"
msgstr "Vocês são alvos fáceis para aquelas metralhadoras Kraut! Afastem-se do penhasco! Movam-se, movam-se!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/11"
msgid "Take down these mortars before they slaughter us!"
msgstr "Destruam esses morteiros antes que nos massacrem!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/12"
msgid "We can't hold them here any longer. Everyone, fall back to the trench lines! Grab what you can and fall back!"
msgstr "Não podemos mais detê-los aqui. Todos, recuem para as linhas de trincheira! Pegue o que puder e recue!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/13"
msgid "Damn, they got too many vehicles, we can't hold them on the open ground! Fall back to the rear trenches!"
msgstr "Maldição — eles têm veículos demais, não podemos detê-los no terreno aberto! Recuem para as trincheiras traseiras!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/14"
msgid "Jerry is pushing our line! Hold your ground!"
msgstr "Os Jerry estão empurrando nossa linha! Segurem suas posições!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/15"
msgid "Hey hot-shot, leave some glory for the rest of us."
msgstr "Ei, fanfarrão — deixe um pouco de glória para o resto de nós."

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/16"
msgid "We don't know what the enemy will throw at us, be prepared for anything. Set up defensive positions overlooking any choke points."
msgstr "Não sabemos o que o inimigo nos lançará — estejam preparados para qualquer coisa. Montem posições defensivas cobrindo todos os pontos de passagem obrigatória."

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/17"
msgid "More Kraut tanks! We don't have very many rockets for the Bazookas, so make every shot count!"
msgstr "Mais tanques Kraut! Não temos muitos foguetes para as bazucas — faça cada tiro valer!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/18"
msgid "Kraut mortars! Get to cover, incoming!"
msgstr "Morteiros Kraut! Cubram-se — chegando!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/19"
msgid "Looks like Jerry has brought up mobile Flak guns! Everyone, get to cover!"
msgstr "Parece que os Jerry trouxeram canhões antiaéreos móveis! Todos, cubram-se!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/20"
msgid "Hold tight, men! We can't let 'em get this ground! The reinforcements are on the way!"
msgstr "Segurem firme, homens! Não podemos deixá-los tomar este terreno! Os reforços estão a caminho!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/21"
msgid "That's it, there's nowhere else to go, we'll make our last stand here!"
msgstr "É isso — não há mais para onde ir. Faremos nossa última resistência aqui!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/22"
msgid "Well look who decided to show up. Cavalry's finally here. Well done boys, I'm proud of each and every one of you. Rangers lead the way!"
msgstr "Olha só quem decidiu aparecer. A Cavalaria finalmente chegou. Muito bem, rapazes — estou orgulhoso de cada um de vocês. Rangers abrem o caminho!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/23"
msgid "Dog Company will begin their assault once you're ready. Just give the word."
msgstr "A Companhia Dog iniciará o assalto assim que você estiver pronto. É só dar a palavra."

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/24"
msgid "Lieutenant, over there! Looks like there are some paratroopers pinned down. They're a ways away from their drop-zones, we need to help those boys out!"
msgstr "Tenente — ali! Parece que há alguns paraquedistas presos. Estão longe de suas zonas de lançamento — precisamos ajudar esses rapazes!"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/gameover_defense_failed"
msgid "The enemy has captured your defensive positions."
msgstr "O inimigo capturou suas posições defensivas."

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/gameover_units_dead"
msgid "You lost all your units."
msgstr "Você perdeu todas as suas unidades."

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/mission_fallback_beach"
msgid "Fallback to the positions on the beach"
msgstr "Recue para as posições na praia"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/mission_fallback_last_stand"
msgid "Fallback to the farthern trench line"
msgstr "Recue para a linha de trincheira mais distante"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/mission_mguns"
msgid "Eliminate the machine gunners on the cliff"
msgstr "Elimine os artilheiros de metralhadora no penhasco"

#, boost-format

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/objective_progress_02_mguns"
msgid "Remaining machine gunners on the cliff: %1%"
msgstr "Atiradores de metralhadora restantes no penhasco: %1%"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/opt01_101st"
msgid "Rescue two stranded 101st Airborne men"
msgstr "Resgatar dois homens da 101ª Aerotransportada isolados"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/reinf_ally_assault"
msgid "Order allied units to attack"
msgstr "Ordenar às unidades aliadas que ataquem"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/secret01_secret01_completed"
msgid "Secret objective - Repair the broken anti-air gun"
msgstr "Objetivo Secreto — Reparar o canhão antiaéreo avariado"

msgctxt "mission/single/04-usa/1944_06_pointe_du_hoc/v2/secret01_secret01_shown"
msgid "Secret objective #1"
msgstr "Objetivo Secreto nº 1"
