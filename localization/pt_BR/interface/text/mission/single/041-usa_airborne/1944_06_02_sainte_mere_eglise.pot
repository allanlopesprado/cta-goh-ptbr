msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/allied/thunder"
msgid "Thunder!"
msgstr "Trovão!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/case1_failed"
msgid "You wandered off and failed to find your Commander. You have been captured - Mission failure!"
msgstr "Você se perdeu e não encontrou o Comandante. Você foi capturado — Missão fracassada!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/date"
msgid "June 6th, 1944 · Ste-Mere-Eglise, Normandy, France."
msgstr "6 de junho de 1944 · Ste-Mère-Église, Normandia, França."

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/debugseen"
msgid "Seen %1% Times"
msgstr "Visto %1% vezes"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/hint/lastwarning"
msgid "Quick! Leave the southwest part of town (red zone) to avoid being captured!"
msgstr "Rápido! Saia da parte sudoeste da cidade (zona vermelha) para evitar ser capturado!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/hint/recruitpara"
msgid "To recruit landing paratroopers, approach close to one, and they will automatically be assigned to your team!"
msgstr "Para recrutar paraquedistas recém-chegados, aproxime-se de um deles e ele será automaticamente adicionado à sua unidade!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/hint/recruitpara2"
msgid "Alternatively, move one of your units near the friendly unit you wish to recruit, hover your cursor over the allied unit, and a grabbing icon will appear."
msgstr "Alternativamente, mova uma de suas unidades para perto da unidade aliada que deseja recrutar, passe o cursor sobre ela e um ícone de mão aparecerá."

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/hint/01avoid"
msgid "Check your map and follow the alternating pointers to reach your objective. Avoid German patrols if you can. Above all, stay away from the southwest part of town (red zone) to avoid being captured!"
msgstr "Verifique o mapa e siga os marcadores alternados para alcançar seu objetivo. Evite patrulhas alemãs sempre que possível. Acima de tudo, mantenha-se longe da parte sudoeste da cidade (zona vermelha) para evitar ser capturado!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/hint/avoidaa"
msgid "Keep away from German AA guns until you regroup with your Commander! Search the area north of the church as indicated."
msgstr "Fique longe dos canhões antiaéreos alemães até se reunir com seu Comandante! Procure a área ao norte da igreja conforme indicado."

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/mission_killaaguns0"
msgid "Destroy the AA guns! <c(e74236)>0/4 destroyed"
msgstr "Destrua os canhões antiaéreos! <c(e74236)>0/4 destruídos"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/mission_killaaguns1"
msgid "Destroy the AA guns! <c(e74236)>1/4 destroyed"
msgstr "Destrua os canhões antiaéreos! <c(e74236)>1/4 destruídos"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/mission_killaaguns2"
msgid "Destroy the AA guns! <c(e74236)>2/4 destroyed"
msgstr "Destrua os canhões antiaéreos! <c(e74236)>2/4 destruídos"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/mission_killaaguns3"
msgid "Destroy the AA guns! <c(e74236)>3/4 destroyed"
msgstr "Destrua os canhões antiaéreos! <c(e74236)>3/4 destruídos"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/mission_killaaguns4"
msgid "Destroy the AA guns! <c(4fe736)>4 destroyed"
msgstr "Destrua os canhões antiaéreos! <c(4fe736)>4 destruídos"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/mission_recruit"
msgid "Recruit ten paratroopers to your group."
msgstr "Recrute dez paraquedistas para o seu grupo."

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/mission_rescue_men"
msgid "Free the captured paratroopers."
msgstr "Liberte os paraquedistas capturados."

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/mission_sniper"
msgid "Kill the German sniper!"
msgstr "Mate o atirador de elite alemão!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/name"
msgid "Dropped into the Fire"
msgstr "Lançados no Fogo"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/name_big"
msgid "Dropped into the Fire"
msgstr "Lançados no Fogo"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/02a"
msgid "Glad to see you! We might just be able to pull this off!"
msgstr "Que bom vê-lo! Talvez possamos conseguir!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/03"
msgid "We must secure a foothold here in the northern section of town while we rally more troops."
msgstr "Precisamos estabelecer uma posição na seção norte da cidade enquanto reunimos mais tropas."

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/04"
msgid "I saw the Krauts rounding up a number of our men. Let's get them outta there!"
msgstr "Eu vi os Krauts capturando alguns de nossos homens. Vamos tirá-los de lá!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/05"
msgid "Some of our boys are still landing in this town. I recommend you recruit any troopers you find!"
msgstr "Alguns de nossos rapazes ainda estão pousando nesta cidade. Recomendo recrutar qualquer soldado que encontrar!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/06"
msgid "Those Kraut Anti-Aircraft guns are still threatening our nearby drop zones. We need to knock them out before they do any more damage."
msgstr "Aqueles canhões antiaéreos alemães ainda ameaçam nossas zonas de lançamento próximas. Precisamos destruí-los antes que causem mais danos."

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/07"
msgid "That looks like the German HQ! We should check for any radios and destroy them."
msgstr "Parece o QG alemão! Devemos verificar se há rádios e destruí-los."

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/08"
msgid "Ah! We've found Jerry's vehicle depot. I bet we can blow it to smithereens!"
msgstr "Ah! Encontramos o depósito de veículos do Jerry. Aposto que podemos explodir tudo!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/convoy01"
msgid "The town is now fully under control, but Jerry is sure to counterattack."
msgstr "A cidade está agora totalmente sob controle, mas o Jerry certamente vai contra-atacar."

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/convoy02"
msgid "The enemy counterattack will soon be gathering from different directions, as indicated on your map. You must ambush it and eliminate all enemy troops before they can deploy!"
msgstr "O contra-ataque inimigo logo se reunirá de diferentes direções, conforme indicado no mapa. Você deve emboscá-los e eliminar todas as tropas inimigas antes que consigam se posicionar!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/secret"
msgid "Oh, what have we here? It seems a supply drop along with a mortar, landed all the way over here! Well, that's something!"
msgstr "Oh, o que temos aqui? Parece que um lançamento de suprimentos junto com um morteiro pousou aqui! Bom, isso é alguma coisa!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/outro_completed"
msgid "Excellent work, we captured and defended Ste-Mere-Eglise against the counterattack! Because we have control over the causeways, the 4th Infantry Division can assault Utah Beach without the threat of an enemy counterattack. Well done!"
msgstr "Excelente trabalho, capturamos e defendemos Ste-Mère-Église contra o contra-ataque! Como temos controle sobre as passagens, a 4ª Divisão de Infantaria pode assaltar a Praia Utah sem a ameaça de um contra-ataque inimigo. Bem feito!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/outro_failed"
msgid "We failed to take Ste-Mere-Eglise! Now the Germans have a clear path to send reinforcements and counterattack our boys on the beaches. The outcome of the invasion is in serious jeopardy! You must try again!"
msgstr "Falhamos em tomar Ste-Mère-Église! Agora os alemães têm um caminho livre para enviar reforços e contra-atacar nossos rapazes nas praias. O resultado da invasão está em sério risco! Tente novamente!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/place"
msgid "82nd Airborne Division \"All American\""
msgstr "82ª Divisão Aerotransportada \"All American\""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/01"
msgid "Shit, I lost all my equipment! All I have left is a knife. I need to find a proper weapon fast!"
msgstr "Merda, perdi todo meu equipamento! Só tenho uma faca. Preciso encontrar uma arma de verdade rapidamente!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/01_bis"
msgid "Looks like Fritz hasn't noticed me yet. I'm sure he won't mind if I take his rifle..."
msgstr "Parece que o Fritz ainda não me viu. Tenho certeza que não vai se importar se eu pegar o rifle dele..."

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/02"
msgid "Hey boys! Glad we found you! Now, grab your rifles and move out!"
msgstr "Ei rapazes! Que bom que os encontramos! Agora, peguem os rifles e partam!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/all_aadestroyed"
msgid "Great! All flak guns are silent!"
msgstr "Ótimo! Todos os canhões antiaéreos estão silenciados!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/convoy"
msgid "Jerry is here! Let's give them a warm welcome. All The Way!"
msgstr "O Jerry está aqui! Vamos dar-lhes uma calorosa recepção. All The Way!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/firstgundestroyed"
msgid "First flak destroyed!"
msgstr "Primeiro canhão antiaéreo destruído!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/flash"
msgid "Flash!"
msgstr "Relâmpago!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/gundestroyed"
msgid "Scratch another Kraut AA!"
msgstr "Mais um canhão antiaéreo Kraut eliminado!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/gundestroyed2"
msgid "One more AA gun knocked out!"
msgstr "Mais um canhão antiaéreo destruído!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/officerfind"
msgid "I saw other men from my 'Stick' drop northwest of the church. I gotta make my way there and find them!"
msgstr "Vi outros homens do meu 'Stick' pousando a noroeste da igreja. Preciso chegar lá e encontrá-los!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/reinf_at"
msgid "Reinforcements, finally! We sure could use the help!"
msgstr "Reforços, finalmente! Realmente precisávamos de ajuda!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/sniper"
msgid "Shit! Taking sniper fire!"
msgstr "Merda! Recebendo fogo de atirador de elite!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/sniper_alt"
msgid "Under sniper fire!"
msgstr "Sob fogo de atirador de elite!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/sniper_killed"
msgid "German sniper eliminated!"
msgstr "Atirador de elite alemão eliminado!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/stayonobj"
msgid "Uh oh! Looks like I'll run into way more Krauts if I keep going this way."
msgstr "Uh oh! Parece que vou encontrar muito mais Krauts se continuar por aqui."

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/recruit_status"
msgid "You recruited %1%/10 paratroopers!"
msgstr "Você recrutou %1%/10 paraquedistas!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/story"
msgid "  6th of June, 1944. The 82nd is on its way to France. In the early hours of D-Day, they will jump over Normandy!\n\n  There’s a simple yet ambitious objective for the 505th battalion: take the village of St. Mère-Église and do it quickly. The drop zone is just northwest of the town, so the plan is to assemble and then move southeast toward it.\n\n  Shortly before 2 AM the 505th jumps into the night, oblivious to the fact the formation is flying much higher than it should.\n\nGood luck!"
msgstr "  6 de junho de 1944. A 82ª está a caminho da França. Nas primeiras horas do Dia D, ela saltará sobre a Normandia!\n\n  O objetivo do batalhão do 505º é simples, porém ambicioso: tomar a vila de St. Mère-Église rapidamente. A zona de lançamento fica a noroeste da cidade, portanto o plano é se concentrar e mover-se para o sudeste em direção a ela.\n\n  Um pouco antes das 2h, o 505º salta na escuridão, sem saber que a formação está voando muito mais alto do que deveria.\n\nBoa sorte!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task0"
msgid "Find a weapon!"
msgstr "Encontre uma arma!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task1"
msgid "Escape the German sentries and find your Commander!"
msgstr "Escape das sentinelas alemãs e encontre seu Comandante!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task2"
msgid "Secure a foothold in the northern side of town!"
msgstr "Estabeleça uma posição no lado norte da cidade!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task3_radio"
msgid "Sabotage the German radio station by bringing your soldiers to it."
msgstr "Sabote a estação de rádio alemã levando seus soldados até ela."

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task3_trucks"
msgid "Destroy the German vehicle depot."
msgstr "Destrua o depósito de veículos alemão."

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task4"
msgid "Ambush and defeat the counterattack!"
msgstr "Embosque e derrote o contra-ataque!"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task_sec"
msgid "Secret Objective #1"
msgstr "Objetivo Secreto nº 1"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task_sec_completed"
msgid "Secret Objective - Find the lost supply drop."
msgstr "Objetivo Secreto - Encontre o lançamento de suprimentos perdido."

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/timerconvoy"
msgid "German counterattack arrives in:"
msgstr "O contra-ataque alemão chega em:"

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/timerconvoywarn"
msgid "<c(ff4200)>German counterattack arrives in:"
msgstr "<c(ff4200)>O contra-ataque alemão chega em:"
