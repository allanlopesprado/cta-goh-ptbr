msgid "Panzer B2"
msgstr ""

msgctxt "mission/single/02-ger/1944_03_narva/reinf/gd"
msgid "Grossdeutschland squad"
msgstr ""

msgctxt "mission/single/02-ger/1944_03_narva/reinf/grille"
msgid "Grille Ausf. K"
msgstr ""

msgctxt "mission/single/02-ger/1944_03_narva/reinf/jagdpanther"
msgid "Jagdpanther"
msgstr ""

msgctxt "mission/single/02-ger/1944_03_narva/reinf/medic"
msgid "Medic"
msgstr ""

msgctxt "mission/single/02-ger/1944_03_narva/reinf/panzer4h"
msgid "Panzer IV Ausf. H"
msgstr ""

msgctxt "mission/single/02-ger/1944_03_narva/reinf/tiger1e"
msgid "Tiger I Ausf. E"
