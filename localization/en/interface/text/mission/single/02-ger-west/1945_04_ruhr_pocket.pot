msgctxt "mission/single/02-ger-west/1945_04_ruhr_pocket/date"
msgid "April 17th, 1945 · Attern, Ruhr, Germany"
msgstr ""

msgctxt "mission/single/02-ger-west/1945_04_ruhr_pocket/doctrine_allround"
msgid "Doctrine: All-Round"
msgstr ""

msgctxt "mission/single/02-ger-west/1945_04_ruhr_pocket/doctrine_defensive"
msgid "Doctrine: Defensive"
msgstr ""

