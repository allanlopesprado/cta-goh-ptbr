msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/case1_failed"
msgid "You wandered off and failed to find your Commander. You have been captured - Mission failure!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/date"
msgid "June 6th, 1944 · Ste-Mere-Eglise, Normandy, France."
msgstr ""

