msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/mission_recruit"
msgid "Recruit ten paratroopers to your group."
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/mission_rescue_men"
msgid "Free the captured paratroopers."
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/mission_sniper"
msgid "Kill the German sniper!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/name"
msgid "Dropped into the Fire"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/name_big"
msgid "Dropped into the Fire"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/02a"
msgid "Glad to see you! We might just be able to pull this off!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/03"
msgid "We must secure a foothold here in the northern section of town while we rally more troops."
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/04"
msgid "I saw the Krauts rounding up a number of our men. Let's get them outta there!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/05"
msgid "Some of our boys are still landing in this town. I recommend you recruit any troopers you find!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/06"
msgid "Those Kraut Anti-Aircraft guns are still threatening our nearby drop zones. We need to knock them out before they do any more damage."
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/07"
msgid "That looks like the German HQ! We should check for any radios and destroy them."
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/08"
msgid "Ah! We've found Jerry's vehicle depot. I bet we can blow it to smithereens!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/convoy01"
msgid "The town is now fully under control, but Jerry is sure to counterattack."
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/convoy02"
msgid "The enemy counterattack will soon be gathering from different directions, as indicated on your map. You must ambush it and eliminate all enemy troops before they can deploy!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/narrator/secret"
msgid "Oh, what have we here? It seems a supply drop along with a mortar, landed all the way over here! Well, that's something!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/outro_completed"
msgid "Excellent work, we captured and defended Ste-Mere-Eglise against the counterattack! Because we have control over the causeways, the 4th Infantry Division can assault Utah Beach without the threat of an enemy counterattack. Well done!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/outro_failed"
msgid "We failed to take Ste-Mere-Eglise! Now the Germans have a clear path to send reinforcements and counterattack our boys on the beaches. The outcome of the invasion is in serious jeopardy! You must try again!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/place"
msgid "82nd Airborne Division \"All American\""
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/01"
msgid "Shit, I lost all my equipment! All I have left is a knife. I need to find a proper weapon fast!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/01_bis"
msgid "Looks like Fritz hasn't noticed me yet. I'm sure he won't mind if I take his rifle..."
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/02"
msgid "Hey boys! Glad we found you! Now, grab your rifles and move out!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/all_aadestroyed"
msgid "Great! All flak guns are silent!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/convoy"
msgid "Jerry is here! Let's give them a warm welcome. All The Way!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/firstgundestroyed"
msgid "First flak destroyed!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/flash"
msgid "Flash!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/gundestroyed"
msgid "Scratch another Kraut AA!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/gundestroyed2"
msgid "One more AA gun knocked out!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/officerfind"
msgid "I saw other men from my 'Stick' drop northwest of the church. I gotta make my way there and find them!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/reinf_at"
msgid "Reinforcements, finally! We sure could use the help!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/sniper"
msgid "Shit! Taking sniper fire!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/sniper_alt"
msgid "Under sniper fire!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/sniper_killed"
msgid "German sniper eliminated!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/player/stayonobj"
msgid "Uh oh! Looks like I'll run into way more Krauts if I keep going this way."
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/recruit_status"
msgid "You recruited %1%/10 paratroopers!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/story"
msgid "  6th of June, 1944. The 82nd is on its way to France. In the early hours of D-Day, they will jump over Normandy!\n\n  There’s a simple yet ambitious objective for the 505th battalion: take the village of St. Mère-Église and do it quickly. The drop zone is just northwest of the town, so the plan is to assemble and then move southeast toward it.\n\n  Shortly before 2 AM the 505th jumps into the night, oblivious to the fact the formation is flying much higher than it should.\n\nGood luck!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task0"
msgid "Find a weapon!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task1"
msgid "Escape the German sentries and find your Commander!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task2"
msgid "Secure a foothold in the northern side of town!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task3_radio"
msgid "Sabotage the German radio station by bringing your soldiers to it."
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task3_trucks"
msgid "Destroy the German vehicle depot."
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task4"
msgid "Ambush and defeat the counterattack!"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task_sec"
msgid "Secret Objective #1"
msgstr ""

msgctxt "mission/single/041-usa_airborne/1944_06_02_sainte_mere_eglise/task_sec_completed"
msgid "Secret Objective - Find the lost supply drop."
msgstr ""

