msgid "Bloody hell! A Tiger tank!"
msgstr ""

msgctxt "mission/single/05-eng/1944_07_13_villers-bocage_skirmish/player_enemy_ace_near"
msgid "For Christ’s sake, take cover and flank him. We must defeat him!"
msgstr ""

