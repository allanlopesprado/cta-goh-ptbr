msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/story"
msgid "The Third Army advance from the south made good progress - Close the pocket.\n\nSoldiers of the 3rd Armored Division! You have a historical opportunity ahead. We can close the pocket around the main German force!\n\nGoals:\n - Advance North to close the pocket.\n - Annihilate the enemy."
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/place"
msgid "Falaise, Calvados"
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/date"
msgid "17 August, 1944"
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/outro_start"
msgid ""
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/outro_completed"
msgid "Well done! This will go down in history as one of those really important victories. You did very well."
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/outro_failed"
msgid "Well that failed. We can't let this happen, go back and try again!"
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/outro_failed_hq"
msgid "We lost our HQ. That spells the end."
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/mission_hq"
msgid "You must hold your field HQ!"
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/mission_attack"
msgid "Punch a hole in the enemy position and drive north!"
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/flag_capture_status"
msgid "Your soldiers secured %1%/7 German positions!"
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/narrator_start0"
msgid "Welcome back to the front line, Lieutenant! This is your field HQ, make sure to keep it under your control!"
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/narrator_start1"
msgid "Gentlemen, there is no choice but to attack immediately. Orders from HQ were quite clear, we can't afford to postpone the attack!"
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/narrator_start2"
msgid "The germans will not expect us to attack from this direction, hopefully. Let's get them!"
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/narrator_start3"
msgid "Begin the attack, meanwhile more reinforcements are being prepared for you!"
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/allied_enemy_near_hq"
msgid "Attention, Germans are approaching our Field HQ!"
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/allied_enemy_plane"
msgid "Enemy plane!!!"
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/allied_enemy_plane2"
msgid "German aircraft inbound!"
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/player_enemy_near_hq"
msgid "We must hold the command post at all costs! There is no room for retreat!"
msgstr ""

msgctxt "mission/single/04-usa/1944_08_skirmish_falaise_pocket/hq_bonus"
msgid "Major! Now you can request an airstrike."
msgstr ""