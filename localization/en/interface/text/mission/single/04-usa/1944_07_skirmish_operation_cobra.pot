msgstr ""

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/narrator_start0"
msgid "Welcome back to the front line, Lieutenant! This is our field HQ, it must remain in our control!"
msgstr ""

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/narrator_start1"
msgid "Operation Cobra is in full swing, a swift assault is necessary to breach through the German lines."
msgstr ""

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/narrator_start2"
msgid "Be quick, be decisive, and try not to lose too many men! Use the terrain to your advantage."
msgstr ""

