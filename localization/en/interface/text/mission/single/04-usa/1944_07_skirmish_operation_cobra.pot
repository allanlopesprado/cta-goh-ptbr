msgid ""
msgstr ""

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/outro_completed"
msgid "Well done! This was the best result we could have expected. HQ will be pleased with your reports."
msgstr ""

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/outro_failed"
msgid "That's quite unexpected! What happened? We need to win this one for Ike!"
msgstr ""

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/outro_failed_hq"
msgid "That borders on disaster. We failed to secure a win, you need to go back and get another effort going!"
msgstr ""

