msgctxt "mission/multi/enemy_plane_alert1"
msgid "Enemy aircraft! He's planning a bombing run!"
msgstr "¡Aeronaves enemigas! ¡Está planeando una pasada de bombardeo!"

msgctxt "mission/multi/enemy_plane_alert2"
msgid "Enemy bomber! Expect air attack on the next pass!"
msgstr ""
"¡Bombardero enemigo! ¡Esperen un ataque aéreo en la próxima pasada!"

msgctxt "mission/multi/minefield_alert1"
msgid "Bloody hell! I see a minefield sign!"
msgstr "¡Maldición! ¡Un cartel de campo de minas!"

msgctxt "mission/multi/minefield_alert2"
msgid "Careful, there are mines nearby!"
msgstr "¡Cuidado! Hay minas cerca..."

msgctxt "mission/multi/minefield_alert3"
msgid "Damn! Enemy planted mines around here! Watch out!"
msgstr "Maldita sea, el enemigo ha puesto minas ¡Tened cuidado!"

msgctxt "mission/multi/display_defense_rus"
msgid ""
"Intelligence reports confirm the enemy is arriving soon from the areas "
"indicated on the map"
msgstr ""
"Los informes de inteligencia confirman que el enemigo llegará pronto "
"desde las zonas indicadas en el mapa."

