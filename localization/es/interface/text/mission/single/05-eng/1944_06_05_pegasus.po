msgctxt "mission/single/05-eng/1944_06_05_pegasus/tasks/secret02_ushanka"
msgid "Secret objective #2"
msgstr "Objetivo secreto n.º 2"

msgctxt ""
"mission/single/05-eng/1944_06_05_pegasus/tasks/secret02_ushanka_completed"
msgid ""
