msgctxt "mission/single/05-eng/1940_05_20_arras_skirmish/name"
msgid "The Battle of Arras [SKIRMISH]"
msgstr "La batalla de Arras [ESCARAMUZA]"

msgctxt "mission/single/05-eng/1940_05_20_arras_skirmish/name_big"
