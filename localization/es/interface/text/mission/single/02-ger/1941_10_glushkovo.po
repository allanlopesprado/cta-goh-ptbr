msgctxt "mission/single/02-ger/1941_10_glushkovo/story"
msgid "'Operation Taifun' just entered its third week. Slowed by bad weather, the final push for Moscow starts with a pincer attack on Vyazma. This mission is about the north pincer, trying to cross the Dnieper."
msgstr "Tercera semana de la \"Operación Taifun\". Ralentizada por el mal tiempo, el empuje final hacia Moscú comienza con un asalto en pinza a Viazma. Esta misión trata sobreel intento por cruzar el Dniéper."

msgctxt "mission/single/02-ger/1941_10_glushkovo/task1"
msgid "Clear the bridge over the Dnieper"
msgstr "Despeja el puente sobre el río Dniéper"

msgctxt "mission/single/02-ger/1941_10_glushkovo/task1_2"
msgid "Clear the the Dnieper fording area"
msgstr "Despeja el vado del Dniéper"

msgctxt "mission/single/02-ger/1941_10_glushkovo/task2"
msgid "Clear out the soviet elevated position"
msgstr "Despeja la posición elevada soviética"

msgctxt "mission/single/02-ger/1941_10_glushkovo/task3"
msgid "Drive the enemy out of Glushkovo"
msgstr "Expulsa al enemigo de Glushkovo"

