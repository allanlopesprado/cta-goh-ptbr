msgstr "6 de marzo, 1945 - Köln, Alemania"

msgctxt "mission/single/04-usa/1945_03_cologne/doctrine_allround"
msgid "Doctrine: All-Round"
msgstr "Doctrina: Completa"

msgctxt "mission/single/04-usa/1945_03_cologne/doctrine_defensive"
msgid "Doctrine: Defensive"
msgstr "Doctrina: Defensiva"

