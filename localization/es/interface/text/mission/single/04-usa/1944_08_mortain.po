msgctxt "mission/single/04-usa/1944_08_mortain/capture"
msgid "Destroy the German force occupying the village!"
msgstr "¡Destruye la fuerza alemana que controla el pueblo!"

msgctxt "mission/single/04-usa/1944_08_mortain/doctrine_allround"
msgid "Doctrine: All-Round"
msgstr "Doctrina: Completa"

