msgstr "Desbloqueo de unidades permanente"

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/name"
msgid "Operation Cobra [SKIRMISH]"
msgstr "Operación Cobra [ESCARAMUZA]"

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/name_big"
msgid "Operation Cobra"
msgstr "Operación Cobra"

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/story"
msgid "Combat Command B, 3rd Armored Division - Operation Cobra.\n\nGentlemen, today the 3rd Armored Division will punch deep into enemy territory.\n\nGoals: \n - Break through the German lines.\n - Capture Marigny."
msgstr ""
"Mando de Combate B, 3ª División Blindada - Operación Cobra.\n"
"\n"
"Señores, hoy la 3 ª División Blindada\n"
"\n"
"se adentrará en territorio enemigo.\n"
"\n"
" \n"
"\n"
"Objetivos:\n"
"\n"
" - Romper las líneas alemanas.\n"
"\n"
" - Capturar Marigny."

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/place"
msgid "Outskirts of Marigny"
msgstr "Afueras de Marigny"

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/date"
msgid "July, 1944"
msgstr "Julio, 1944"

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/outro_start"
msgid ""
msgstr ""

msgctxt ""
"mission/single/04-usa/1944_07_skirmish_operation_cobra/outro_completed"
msgid ""
"Well done! This was the best result we could have expected. HQ will be "
"pleased with your reports."
msgstr ""
"¡Enhorabuena! Este es el mejor resultado que podíamos esperar. El cuartel "
"general estará encantado con sus informes."

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/outro_failed"
msgid ""
"That's quite unexpected! What happened? We need to win this one for Ike!"
msgstr "¡Eso fue inesperado! ¿Qué ha pasado? ¡Tenemos que ganar esto por Ike!"

msgctxt ""
"mission/single/04-usa/1944_07_skirmish_operation_cobra/outro_failed_hq"
msgid ""
"That borders on disaster. We failed to secure a win, you need to go back and "
"get another effort going!"
msgstr ""
"Ha sido un desastre. No hemos asegurado la victoria, ¡hay que volver atrás y "
"esforzarse más!"

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/mission_hq"
msgid "You must hold your field HQ!"
msgstr "¡Debes defender tu cuartel general!"

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/mission_attack"
msgid "Punch a hole in the enemy position and drive north!"
msgstr "Ábrete hueco a traves de las posiciones enemigas y prosigue hacia el norte"

msgctxt ""
"mission/single/04-usa/1944_07_skirmish_operation_cobra/flag_capture_status"
msgid "Your soldiers secured %1%/7 German positions!"
msgstr "¡Tus soldados aseguraron %1%/7 posiciones alemanas!"

msgctxt ""
"mission/single/04-usa/1944_07_skirmish_operation_cobra/narrator_start0"
msgid ""
"Welcome back to the front line, Lieutenant! This is our field HQ, it must "
"remain in our control!"
msgstr ""
"¡Bienvenido de nuevo al frente, Teniente! ¡Este es nuestro cuartel general "
"de campo, debemos mantenerlo bajo nuestro control!"

msgctxt ""
"mission/single/04-usa/1944_07_skirmish_operation_cobra/narrator_start1"
msgid ""
"Operation Cobra is in full swing, a swift assault is necessary to breach "
"through the German lines."
msgstr ""
"La Operación Cobra está en pleno apogeo, hay que realizar un asalto rápido "
"para atravesar las líneas alemanas."

msgctxt ""
"mission/single/04-usa/1944_07_skirmish_operation_cobra/narrator_start2"
msgid ""
"Be quick, be decisive, and try not to lose too many men! Use the terrain to "
"your advantage."
msgstr ""
"¡Sé rápido, sé decisivo e intenta no perder demasiados hombres! Utiliza el "
"terreno a tu favor."

msgctxt ""
"mission/single/04-usa/1944_07_skirmish_operation_cobra/narrator_start3"
msgid ""
"More reinforcements will become available as you progress with your assault!"
msgstr "¡Dispondrás de más refuerzos a medida que avances en tu asalto!"

msgctxt ""
"mission/single/04-usa/1944_07_skirmish_operation_cobra/allied_enemy_near_hq"
msgid "Gentlemen! Germans are close to our Field HQ!"
msgstr "¡Caballeros! ¡Los alemanes están cerca de nuestro cuartel general!"

msgctxt ""
"mission/single/04-usa/1944_07_skirmish_operation_cobra/allied_enemy_plane"
msgid "Enemy plane!!!"
msgstr "¡¡¡Avión enemigo!!!"

msgctxt ""
"mission/single/04-usa/1944_07_skirmish_operation_cobra/allied_enemy_plane2"
msgid "German aircraft inbound!"
msgstr "¡Aviones alemanes entrando!"

msgctxt ""
"mission/single/04-usa/1944_07_skirmish_operation_cobra/player_enemy_near_hq"
msgid "We must hold our command post! There is no room for surrender!"
msgstr "¡Debemos mantener el puesto de mando! ¡No hay lugar para la rendición!"

msgctxt "mission/single/04-usa/1944_07_skirmish_operation_cobra/hq_bonus"
msgid "Major! Now you can request an airstrike."
msgstr "¡Mayor! Ahora puede solicitar un ataque aéreo."
