msgctxt "mission/single/04-usa/player_reinf_arrive"
msgid "Our reinforcements are here!"
msgstr "¡Nuestros refuerzos están aquí!"

msgctxt "mission/single/04-usa/player_reinf_arrive_alt"
msgid "Reinforcements have arrived!"
msgstr "¡Los refuerzos han llegado!"

msgctxt "mission/single/04-usa/allied_obj_capture"
msgid "Strategic position secured!"
msgstr "¡Posición estratégica asegurada!"

msgctxt "mission/single/04-usa/allied_obj_capture_alt"
msgid "Key point captured!"
msgstr "¡Punto clave capturado!"

msgctxt "mission/single/04-usa/allied_obj_lost"
msgid "We lost a strategic point!"
msgstr "¡Hemos perdido un punto estratégico!"

msgctxt "mission/single/04-usa/allied_obj_lost_alt"
msgid "Strategic location was retaken by enemy soldiers!"
msgstr "¡Lugar estratégico retomado por soldados enemigos!"

msgctxt "mission/single/04-usa/incoming_enemy_arty"
msgid "Enemy artillery incoming! On the ground!"
msgstr "¡Artillería enemiga en camino! ¡Al suelo!"

msgctxt "mission/single/04-usa/repair_abandoned_tank"
msgid "Repair and recover this abandoned enemy tank!"
msgstr "¡Repara y recupera este tanque enemigo abandonado!"
