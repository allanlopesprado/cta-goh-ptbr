msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/name"
msgid "Battle of the Bulge [SKIRMISH]"
msgstr "Batalla de las Ardenas [ESCARAMUZA]"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/name_big"
msgid "Battle of the Bulge"
msgstr "Batalla de las Ardenas"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/story"
msgid "The Battle of the Bulge\n\nAfter the initial battles, you are surrounded by Germans. Time for a breakout attempt!\n\nGoals:\n - Break the encirclement.\n - Close the front."
msgstr ""
"La Batalla de las Ardenas#Después de las batallas iniciales, estás rodeado "
"de alemanes.\n"
"\n"
"¡Es hora de intentar fugarse!\n"
"\n"
" \n"
"\n"
"Objetivos:\n"
"\n"
" - Romper el cerco.\n"
"\n"
" - Cerrar el frente."

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/place"
msgid "Region between Hotton and Bastogne"
msgstr "Región entre Hotton y Bastogne"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/date"
msgid "January, 1945"
msgstr "Enero, 1945"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/outro_start"
msgid ""
msgstr ""

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/outro_completed"
msgid "Well done! We'll drive them back to their starting point next!"
msgstr "¡Bien hecho! ¡Los haremos retroceder hasta su punto de partida!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/outro_failed"
msgid ""
"This is not the desired outcome. You need to regroup, and use different "
"tactics!"
msgstr ""
"Este no es el resultado que esperábamos. ¡Tienes que reagruparte y "
"utilizar otras tácticas!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/outro_failed_hq"
msgid ""
"We have been defeated at the Ardennes. With nothing to stop the Germans, "
"they may get to Antwerp and cut our european armies in two!"
msgstr ""
"Hemos sido derrotados en las Ardenas. ¡Sin nada que detenga a los "
"alemanes, pueden llegar a Amberes y dividir nuestros ejércitos europeos en "
"dos!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/mission_hq"
msgid "You must hold your field HQ!"
msgstr "¡Debes defender tu cuartel general!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/mission_attack"
msgid "Punch a hole in the enemy position and drive east!"
msgstr "¡Ábrete paso entre los enemigos y dirígete hacia el este!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/flag_capture_status"
msgid "Your soldiers secured %1%/7 German positions!"
msgstr "¡Tus soldados aseguraron %1%/7 posiciones alemanas!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/narrator_start0"
msgid ""
"The German assault on the Ardennes has taken us by complete surprise! "
"Lieutenant, This is your field HQ, as you know by now, we cannot afford to "
"lose it!"
msgstr ""
"El asalto alemán en las Ardenas nos ha tomado por sorpresa Teniente, este "
"es su cuartel general, como ya sabe, ¡no podemos permitirnos perderlo!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/narrator_start1"
msgid ""
"The Krauts hit us hard during Christmas, but our new year's resolution is "
"to turn the tables around! Seize the initiative and drive the Nazis "
"back to Germany!"
msgstr ""
"Los alemanes nos golpearon duro durante las Navidades, ¡pero nuestro "
"propósito de año nuevo es darle la vuelta a la tortilla! ¡Toma la "
"iniciativa y manda a los nazis de vuelta a Alemania!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/narrator_start2"
msgid ""
"Expect heavy resistance from their well-trained and battle hardened troops."
msgstr ""
"Se espera una fuerte resistencia por parte de sus tropas, bien entrenadas "
"y con experiencia en batalla."

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/narrator_start3"
msgid "Begin the attack, Lieutenant! Show them what we're made of!"
msgstr "¡Lance el ataque, Teniente! ¡Muéstrales de qué estamos hechos!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/allied_enemy_near_hq"
msgid "Gentlemen! Germans are close to our Field HQ!"
msgstr "¡Caballeros! ¡Los alemanes están cerca de nuestro cuartel general!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/allied_enemy_plane"
msgid "Enemy plane!!!"
msgstr "¡¡¡Avión enemigo!!!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/allied_enemy_plane2"
msgid "German aircraft inbound!"
msgstr "¡Se acercan aviones alemanes!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/player_enemy_near_hq"
msgid "We must hold our command post! You have your orders!"
msgstr "¡Debemos mantener nuestro puesto de mando! ¡Siga sus órdenes!"

msgctxt "mission/single/04-usa/1944_12_skirmish_bulge/hq_bonus"
msgid ""
"Lieutenant! Now may now request an airstrike. The skies have cleared since "
"the Krauts began their offensive, and now wse may resume our air supremacy!"
msgstr ""
"¡Teniente! Ahora podemos solicitar un ataque aéreo. ¡Los cielos se han "
"despejado desde que los alemanes comenzaron su ofensiva, y ahora podemos "
"recuperar la supremacía aérea!"
