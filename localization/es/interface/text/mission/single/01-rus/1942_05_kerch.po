msgctxt "mission/single/01-rus/1942_05_kerch/date"
msgid "12th of May, 1942 ·  Kerch peninsula, Crimea"
msgstr "12 de mayo de 1942 · Península de Kerch, Crimea"

msgctxt "mission/single/01-rus/1942_05_kerch/name"
msgid "Operation Bustard Hunt"
msgstr "Operación Caza del otídido"

msgctxt "mission/single/01-rus/1942_05_kerch/name_big"
msgid "Operation Bustard Hunt"
msgstr "Operación Caza del otídido"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_01"
msgid "What is that in front of us?"
msgstr "¿Qué es eso que hay enfrente?"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_02"
msgid "It's an enemy tank!"
msgstr "¡Es un tanque enemigo!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_03"
msgid "Dismount, everybody out!"
msgstr "¡Bajaos, salid todos!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_05"
msgid "Men! Take out that tank!"
msgstr "¡Soldados! ¡Acabad con el tanque!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_06"
msgid "Flank the enemy at once, otherwise our Comrades will be obliterated."
msgstr "Flanquead al enemigo ya o nuestros camaradas acabarán bajo tierra."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_06_1"
msgid "Enemy aircraft! Take cover!"
msgstr "¡Avión enemigo! ¡Cubríos!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_07"
msgid " We will mourn them later. Keep going, otherwise we will be dead too!"
msgstr " Ya nos lamentaremos más tarde. ¡Aguantad, hay que sobrevivir!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_08"
msgid "Comrades, you are now under my command."
msgstr "Camaradas, vais a estar a mis órdenes."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_09"
msgid "We must protect our trucks along the length of the entire road!"
msgstr "¡Tenemos que proteger los camiones hasta el final de la carretera!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_10"
msgid ""
"Prepare defensive positions, erect trenches and foxholes, and mine the "
"approaches to the road! You can find ammunition and mines in the trucks."
msgstr "¡Preparad las defensas, cavad trincheras, hoyos y minad las entradas a la carretera! Los camiones contienen munición y minas."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_11"
msgid "We were attacked by enemy recon units."
msgstr "Nos han atacado unidades de reconocimiento enemigas."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_12"
msgid ""
"The Germans broke through to the road, regain the initiative and drive them "
"out!"
msgstr "Los alemanes han llegado a la carretera, ¡retomad la iniciativa y expulsadlos!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_13"
msgid "Secure the positions near the road! Drive the germans away!"
msgstr "¡Asegurad las posiciones junto a la carretera! ¡Echad a las ratas alemanas!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_14"
msgid ""
"We need to send scouts up ahead. Ivanov, move forward and report German "
"movement."
msgstr "Tenemos que enviar exploradores. Ivanov, adelántate e infórmanos sobre todo lo que hagan los alemanes."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_15"
msgid "They are coming back in full strength. Hold positions!"
msgstr "Vuelven con todo. ¡Resistid!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_16"
msgid "We must use this time to strengthen the defences."
msgstr "Tenemos que aprovechar y fortalecer las protecciones."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_17"
msgid "Hold the right flank!"
msgstr "¡Defended el flanco derecho!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_18"
msgid "Hold the left flank !"
msgstr "¡Defended el flanco izquierdo!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_19"
msgid "Hold the center! We can't lose it!"
msgstr "¡Defended la zona central! ¡No la perdamos!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_20"
msgid "We are losing too many transports! Do something!"
msgstr "¡Estamos perdiendo demasiados medios de transporte! ¡Haced algo!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_21"
msgid "You failed at protecting the convoy, you will be held accountable!"
msgstr "No habéis conseguido proteger el convoy, ¡lo pagaréis caro!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_22"
msgid "We are still losing trucks! Do something !"
msgstr "¡Seguimos perdiendo camiones! ¡Haced algo!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_23"
msgid "They destroyed our trucks! Take back the road!"
msgstr "¡Se han cargado nuestros camiones! ¡Recuperad la carretera!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_24"
msgid "We must warn the remaining convoy so they can take another route."
msgstr "Tenemos que avisar a los convoyes que quedan para que cambien de ruta."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_25"
msgid "Excellent! Retreat to the prepared line of defense."
msgstr "¡Genial! Retiraos hacia la línea defensiva."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_26"
msgid "We have lost the anti-aircraft gun, we can't shoot down any aircraft!"
msgstr "Hemos perdido el cañón antiaéreo, ¡no podemos derribar aviones!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_27"
msgid "We have lost a few trucks, but you completed the task!"
msgstr "Hemos perdido varios camiones, pero ¡has conseguido completar la tarea!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part1_28"
msgid ""
"To retreat, move your soldiers on to the road and you will leave this "
"sector. Any soldier that remains fighting in the open will sacrifice himself "
"here, covering your retreat. "
msgstr "Para retirarte, traslada tus soldados a la carretera para abandonar el sector. Los soldados que permanezcan luchando en campo abierto darán su vida por cubrir tu retirada. "

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part2_01"
msgid "We have almost reached our position."
msgstr "Ya casi hemos llegado a nuestra posición."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part2_02"
msgid ""
"What the hell?! The Fascists have already reached the first line of defense. "
"Stand your ground! Move into position and hold the line!"
msgstr "¡¿Qué narices?! Los fascistas han conseguido llegar alcanzar la primera línea defensiva, ¡aguantad! ¡Posicionaos y resistid!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part2_03"
msgid ""
"The Germans are moving from the west towards the trucks! Protect the "
"vehicles to the last man!"
msgstr "¡Los alemanes avanzan desde el oeste hacia los camiones! ¡Proteged los vehículos cueste lo que cueste!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part2_04"
msgid "We regained control of the defense line!"
msgstr "¡Hemos retomado el control de la línea defensiva!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part2_07"
msgid "Truck driver is down! Now the truck is a sitting duck!"
msgstr "¡El piloto del camión ha sido abatido! ¡El camión está en peligro!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part2_08"
msgid "They destroyed the truck, damn it! Do something about it!"
msgstr "¡Han destruido el camión, joder! ¡Haced algo!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part2_09"
msgid ""
"We've managed to do our best holding this defensive perimeter, but we must "
"now pull back to the second line of defense!"
msgstr "Hemos conseguido mantener el perímetro defensivo, ¡aunque ahora tenemos que retroceder a la segunda línea!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part2_10"
msgid "Hold the line at all costs!"
msgstr "¡Defended la línea con uñas y dientes!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part2_11"
msgid ""
"We're losing ground too fast, damn it! We're pulling back to the second line "
"of defense!"
msgstr "¡Estamos perdiendo terreno, me cago en todo! ¡Retrocedamos a la segunda línea defensiva!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part2_12"
msgid "The Germans are coming from the North West!"
msgstr "¡Los alemanes se acercan por el noroeste!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part2_13"
msgid "The Fascists are coming from the beach!"
msgstr "¡Los fascistas se acercan por la fisura!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part2_14"
msgid ""
"They enemy is advancing along the centre, aim your guns towards the road!"
msgstr "¡El enemigo está avanzando por el centro, apuntad a la carretera!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part2_15"
msgid "The enemy has captured our first line!"
msgstr "¡El enemigo ha capturado nuestra primera línea!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer01/part2_16"
msgid "Requesting naval artillery support!"
msgstr "¡Solicito artillería naval de apoyo!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part1_01"
msgid "What happened here?"
msgstr "¿Qué ha pasado?"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part1_02"
msgid ""
"I will grant you reinforcements. Don't waste them, and don't allow the enemy "
"to destroy any our convoys."
msgstr "Voy a solicitar refuerzos. No los desperdicies y encárgate de que el enemigo no destruya ningún convoy."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part1_03"
msgid ""
"I will go to HQ with Belousov to report german movements. Belousov, get into "
"the second truck!"
msgstr "Voy a ir a la sede con Belousov a informar sobre todo lo que hagan los alemanes. Belousov, ¡móntate en el segundo camión!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part1_04"
msgid "I will go to HQ to report on the situation. "
msgstr "Voy a ir a la sede a informar de la situación. "

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part1_04_1"
msgid "Good luck comrades."
msgstr "Buena suerte, camaradas."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part1_05"
msgid ""
"HQ allocated reinforcements to cover the column! Use the anti-aircraft gun "
"to destroy the enemy fighter aircraft."
msgstr "¡La sede ha asignado refuerzos para que cubran la columna! Usa el cañón antiaéreo para destruir el avión enemigo."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part1_06"
msgid ""
"We are preparing the main defensive position. As soon as the column is safe, "
"pull back!"
msgstr "Estamos organizando la posición defensiva principal. ¡Retírate en cuanto la columna sea segura!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part2_01"
msgid ""
"It is nice to see you alive and well, Comrade. We have a critical situation. "
"The Germans broke through the defenses in the nearby sector and are dashing "
"towards our position. Our right flank was completely obliterated."
msgstr "Me alegra verte sano y salvo, camarada. La situación es delicada. Los alemanes han roto las defensas del sector cercano y se aproximan a nuestra posición. El flanco derecho ha sufrido grandes daños."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part2_02"
msgid ""
"Take command of several of my soldiers. I also transfer my medics to your "
"command. Try to heal the wounded and stabilise the frontline!"
msgstr "Toma el control de varios soldados míos, voy a enviarte mis médicos. ¡Intenta curar a los heridos y estabilizar el frente!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part2_03"
msgid ""
"On the south, German planes bombed the last convoy. Two cars loaded with "
"wounded soldiers were left stranded. You must protect the vehicles from "
"enemy attacks at any rate! Use the landscape as cover, and don't let the "
"enemy kill our wounded!"
msgstr "Los aviones alemanes han bombardeado el último convoy que nos quedaba al sur. Quedan dos vehículos con soldados heridos. ¡Protege los vehículos de cualquier embestida enemiga, cúbrete usando el entorno y que los hostiles no se acerquen a nuestros hombres heridos!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part2_04_lost"
msgid ""
"They destroyed our line of defense! You were unable to cope with the task at "
"hand. Traitor!"
msgstr "¡Han destruido la línea defensiva! No has podido cumplir la misión, ¡traidor!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part2_05"
msgid ""
"Great job, you regained control of the defense line. There is no time to "
"waste. The main German forces can be here at any moment. Distribute the "
"troops along the defense line. Try to make the surviving guns and tanks be "
"operational, the Germans will press us without mercy."
msgstr "Bien hecho, has retomado el control de la línea defensiva. No hay tiempo que perder, las fuerzas alemanas estarán al caer. Reparte las tropas por la línea defensiva e intenta sacar el máximo partido a los tanques y armas operativos, los alemanes no tendrán piedad."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part2_06"
msgid ""
"HQ reports it will take a considerable amount of time to evacuate. We need "
"to delay the enemy for as long as possible and then retreat away from the "
"sector. You will be informed of the progress of the evacuation."
msgstr "La sede advierte que la evacuación llevará un tiempo. Tenemos que retrasar al enemigo durante el mayor tiempo posible y después tratar de abandonar el sector. Te mantendremos informado sobre la evacuación."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part2_07"
msgid ""
"They're hitting us hard! Take some of the reserve troops and plug in the "
"gaps along the defensive line!"
msgstr "¡Nos atacan con todo! ¡Saca algunas tropas de la reserva y cubre los huecos que hay en la línea defensiva!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part2_09"
msgid ""
"They're heading to the evacuation point across the beach! Don't let them get "
"through!"
msgstr "¡Se dirigen al punto de evacuación de la playa! ¡Que no lleguen!"

msgctxt ""
"mission/single/01-rus/1942_05_kerch/narrator/officer03/part2_10_line2_lost"
msgid ""
"You lost the second line of defense, now the Germans have nothing stopping "
"them from reaching our ships!"
msgstr "Has perdido la segunda línea defensiva, ¡ahora los alemanes tienen vía libre para llegar a nuestros barcos!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part2_11"
msgid ""
"The Black Sea fleet light cruiser 'Voroshilov' is nearby, they are ready to "
"provide us fire support. Try to fire large enemy troop concentrations, at "
"this range the accuracy of the barrage will be low."
msgstr "Cerca se encuentra el crucero ligero Voroshilov de la Flota del Mar Negro, listo para brindarnos fuego de apoyo. Intenta disparar a grupos grandes de tropas, a esta distancia la precisión de la barrera es baja."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part2_12"
msgid ""
"Our aircraft have reported enemy artillery movement into our sector. It's "
"likely they will deploy them in the whereabouts to shoot at our naval "
"vessels. I'll report the situation to headquarters!"
msgstr "Nuestro avión advierte que hay artillería enemiga en nuestro sector. Es probable que vayan a desplegarla en los alrededores con el fin de acabar con nuestros navíos. ¡Voy a informar a la sede!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part2_13"
msgid ""
"Enemy artillery has begun to fire at our ships! We must stop them! Our "
"comrades' blood is in your hands!"
msgstr "¡La artillería enemiga ha abierto fuego contra nuestros barcos! ¡Hay que detenerla! ¡Las vidas de nuestros camaradas están en tus manos!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part2_13_1"
msgid ""
"The Germans have broken through! You have failed to protect the evacuation "
"point."
msgstr "¡Los alemanes han entrado! No has conseguido proteger el punto de evacuación."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/officer03/part2_14"
msgid ""
"HQ is now granting you our last reserves to break through the Germans and "
"destroy the enemy artillery!"
msgstr "¡La sede te va a enviar nuestras últimas reservas para romper la línea alemana y destruir la artillería enemiga!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_01"
msgid ""
"The enemy plane's been hit! We're putting our air force to shame with our "
"endless retreat!"
msgstr "¡Avión enemigo alcanzado! ¡Nuestras fuerzas aéreas sienten vergüenza por la retirada!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_02"
msgid "I'm going right out of the line of fire!"
msgstr "¡Voy a abandonar la línea de disparo!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_03"
msgid "Tank moving to the right flank!"
msgstr "¡Tanque desplazándose al flanco derecho!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_04"
msgid "Tank moving to the left flank!"
msgstr "¡Tanque desplazándose al flanco izquierdo!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_05"
msgid "German squad on the right flank!"
msgstr "¡Escuadrón alemán en el flanco derecho!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_05_1"
msgid "We're fighting out in the open. Enemy aircraft will shred us to pieces."
msgstr "Estamos combatiendo en campo abierto. El avión enemigo nos va a hacer añicos."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_06"
msgid "Comrade Commander, we have lost Voloshin's squad!"
msgstr "Comandante, ¡hemos perdido el escuadrón de Voloshin!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_07"
msgid "The enemy is retreating!"
msgstr "¡El enemigo se retira!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_08"
msgid "The enemy has been destroyed."
msgstr "Enemigo destruido."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_09"
msgid "The convoy is on its way!"
msgstr "¡El convoy está en camino!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_10"
msgid "The next convoy is here!"
msgstr "¡Ya está aquí el próximo convoy!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_11"
msgid "Another convoy is on its way!"
msgstr "¡Hay otro convoy en camino!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_12"
msgid "Incoming Germans!"
msgstr "¡Se acercan los alemanes!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_13"
msgid "Another wave of Germans!"
msgstr "¡Otra oleada de alemanes!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_14"
msgid "They stopped pressing!"
msgstr "¡Han dejado de presionar!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_15"
msgid "We are under attack from that Messerschmitt! shoot it down!"
msgstr "¡Nos disparan desde el Messerschmitt! ¡Derríbalo!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_16"
msgid "Plane inbound from the seaside!"
msgstr "¡Hay un avión que viene de la costa!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_17"
msgid "Enemy airplane incoming from the west!"
msgstr "¡Avión enemigo aproximándose por el oeste!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_18"
msgid "Enemy fighter coming from the east!"
msgstr "¡Aeronave enemiga aproximándose por el este!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_19"
msgid "Got 'em!"
msgstr "¡Son míos!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_21"
msgid "Out of range... I hope he will not strafe our convoys..."
msgstr "Fuera de alcance... Espero que no ametralle a nuestros convoyes..."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_22"
msgid "They are doubling their efforts!"
msgstr "¡Están solicitando refuerzos!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_23"
msgid "Artillery strike! Take cover!"
msgstr "¡Artillería! ¡A cubierto!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_24"
msgid "The Fascists are coming at us once more!"
msgstr "¡Vuelven los fascistas a por nosotros!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part1_26"
msgid "We haven't lost any trucks ! Great!"
msgstr "¡No hemos perdido ni un solo camión! ¡Excelente!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part2_01"
msgid "We fixed the first truck. It's heading out."
msgstr "Hemos arreglado el primer camión, ya sale."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part2_02"
msgid "The second truck is also eggressing!"
msgstr "¡El segundo camión también se está marchando!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part2_03"
msgid "The truck has left this area!"
msgstr "¡El camión ha abandonado la zona!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part2_04"
msgid "The trucks have left this area!"
msgstr "¡Los camiones han abandonado la zona!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part2_05"
msgid "Artillery shelling, take cover! Lie down in your trenches! "
msgstr "¡Fuego de artillería, a cubierto! ¡Cubríos con las trincheras! "

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part2_06"
msgid "They're coming!"
msgstr "¡Ya vienen!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part2_07_beach"
msgid "The enemy is coming in from the coastline!"
msgstr "¡Vienen enemigos por la costa!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part2_08"
msgid "The last ship sailed away from the coast. A job well done, Comrade!"
msgstr "El último barco ha zarpado. ¡Buen trabajo, camarada!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part2_09"
msgid ""
"Enemy artillery took up positions on the shore! It will take a time to "
"adjust their guns to fire. Something needs to be done immediately, commander."
msgstr "¡La artillería enemiga se ha afianzado en la costa! Tardarán un tiempo en ajustar las armas, pero tenemos que hacer algo de inmediato, comandante."

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part2_10"
msgid "Their artillery missed by a hundred meters! They are zeroing in fast!"
msgstr "¡Sus artilleros han abierto fuego a 100 metros de nuestra posición! ¡Están fijando la mira!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part2_11"
msgid "The enemy has missed our ship by a mere couple of metres!"
msgstr "¡El enemigo ha abierto fuego a solo unos metros del barco!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part2_12"
msgid "They sank our ship!"
msgstr "¡Nos han hundido el barco!"

msgctxt "mission/single/01-rus/1942_05_kerch/narrator/soldier/part2_13"
msgid "We destroyed the enemy battery! Our ships are safe!"
msgstr "¡Hemos destruido la artillería enemiga! ¡Nuestros barcos están a salvo!"

msgctxt "mission/single/01-rus/1942_05_kerch/opt_task_01"
msgid "Mine the approaches to the road"
msgstr "Mina las entradas a la carretera"

msgctxt "mission/single/01-rus/1942_05_kerch/opt_task_01_1"
msgid "Dig trenches and foxholes to defend the road"
msgstr "Cava trincheras y hoyos para proteger la carretera"

msgctxt "mission/single/01-rus/1942_05_kerch/opt_task_02"
msgid "Shoot down a german plane!"
msgstr "¡Derriba un avión alemán!"

msgctxt "mission/single/01-rus/1942_05_kerch/outro_completed"
msgid ""
"Eventually, the red army evacuated what was left of the 44th army by sea. A "
"rear guard was left behind to \n"
"cover the evacuation, which took place on the east beaches. Some 116.000 "
"soldiers escaped. Later that summer, Sevastopol fell; \n"
"but the red army would return in 1944 to take all of it back."
msgstr "Finalmente, el Ejército Rojo evacuó vía marítima los restos de la 44.ª Guardia. Dejaron una guardia trasera para \ncubrir la evacuación, que tuvo lugar en las playas orientales. Unos 116 000 soldados lograron escapar. Más tarde ese mismo verano, Sevastopol colapsó, \naunque el Ejército Rojo volvió en 1944 para recuperar lo que una vez le pertenecía."

msgctxt "mission/single/01-rus/1942_05_kerch/outro_failed"
msgid ""
"Because you did not do enough to delay the Germans, they are now driving "
"toward the east beaches! This means \n"
"the evacuation will turn into a bloodbath. After that, the Germans will be "
"able to cross into the Taman peninsula almost unopposed. \n"
"Their attack plan for next year can now be altered to include an army group "
"marching on Maikop from just 300Km. to the west."
msgstr "Como no has conseguido retrasar a las tropas alemanas, ¡ahora se dirigen a las playas orientales! Por lo que \nla evacuación va a ser una masacre. Después, los alemanes podrán cruzar la península de Tamán sin apenas oposición. \nPodemos detener la ofensiva que tienen planeada de cara al año que viene incluyendo un grupo militar que se desplace en Maikop 300 km hacia el oeste."

msgctxt "mission/single/01-rus/1942_05_kerch/part1_retreat_button"
msgid "Retreat"
msgstr "Retirada"

msgctxt "mission/single/01-rus/1942_05_kerch/part1_retreat_button_hint"
msgid "Order soldiers to retreat to allied positions"
msgstr "Ordena a los soldados que se retiren a posiciones aliadas."

msgctxt "mission/single/01-rus/1942_05_kerch/part2_naval_art"
msgid "Naval artillery"
msgstr "Artillería naval"

msgctxt "mission/single/01-rus/1942_05_kerch/part2_naval_art_hint"
msgid "Shelling of naval artillery"
msgstr "Fuego de artillería naval"

msgctxt "mission/single/01-rus/1942_05_kerch/place"
msgid "44th Army"
msgstr "44.ª Armada"

msgctxt "mission/single/01-rus/1942_05_kerch/sec_task_01"
msgid "Not a single truck should be destroyed"
msgstr "Que no destruyan ni un camión"

msgctxt "mission/single/01-rus/1942_05_kerch/start"
msgid "May 5 1942. Kerch peninsula"
msgstr "5 de mayo de 1942. Península de Kerch"

msgctxt "mission/single/01-rus/1942_05_kerch/story"
msgid "What the Germans call Operation Bustard Hunt is now underway. The Red Army tries to stop them, having built defensive lines stretching from coast to coast across the peninsula."
msgstr "La operación denominada \"Caza del otídido\" por los alemanes está en curso. El Ejército Rojo intentará detenerlos con líneas defensivas desplegadas de costa a costa a lo largo de la península."

msgctxt "mission/single/01-rus/1942_05_kerch/task_01"
msgid "Destroy the enemy tank and infantry"
msgstr "Destruye el tanque e infantería enemigos"

msgctxt "mission/single/01-rus/1942_05_kerch/task_02"
msgid "Dig in and prepare the defensive line"
msgstr "Cava y prepara la línea defensiva"

msgctxt "mission/single/01-rus/1942_05_kerch/task_03"
msgid "Protect the retreating convoy from the enemy"
msgstr "Protege el convoy en retirada"

msgctxt "mission/single/01-rus/1942_05_kerch/task_03_1"
msgid "Send a soldier to warn the convoy"
msgstr "Envía un soldado a que advierta al convoy"

msgctxt "mission/single/01-rus/1942_05_kerch/task_04"
msgid "Go to the frontline and take command"
msgstr "Ve a la primera línea y toma el control"

msgctxt "mission/single/01-rus/1942_05_kerch/task_05"
msgid "Get to the positions and find out the situation"
msgstr "Posiciónate y averigua qué sucede"

msgctxt "mission/single/01-rus/1942_05_kerch/task_06"
msgid ""
"Take back control of the position and protect the trucks with the wounded"
msgstr "Retoma el control de la posición y protege los camiones con camaradas heridos"

msgctxt "mission/single/01-rus/1942_05_kerch/task_07"
msgid "Hold the first line of defence"
msgstr "Defiende la primera línea defensiva"

msgctxt "mission/single/01-rus/1942_05_kerch/task_08"
msgid "Hold the second line of defence"
msgstr "Defiende la segunda línea defensiva"

msgctxt "mission/single/01-rus/1942_05_kerch/task_09"
msgid "Defend the Soviet Evacuation from the Peninsula"
msgstr "Protege la evacuación soviética de la península"

#, boost-format
msgctxt "mission/single/01-rus/1942_05_kerch/task_09_loaded"
msgid "%1%% loaded to ships"
msgstr "%1% % cargado en barcos"

msgctxt "mission/single/01-rus/1942_05_kerch/task_10"
msgid "Attack and destroy the enemy artillery battery"
msgstr "Ataca y destruye la batería de artillería enemiga"

msgctxt "mission/single/01-rus/1942_05_kerch/timer"
msgid "Time to warn the convoy:"
msgstr "Tiempo para advertir al convoy:"

msgctxt "mission/single/01-rus/1942_05_kerch/timer_convoy"
msgid "Next convoy in:"
msgstr "Próximo convoy en:"

#, boost-format
msgctxt "mission/single/01-rus/1942_05_kerch/trucks_lost_1"
msgid "You lost %1% of 5 trucks"
msgstr "Has perdido %1% camiones de 5"
