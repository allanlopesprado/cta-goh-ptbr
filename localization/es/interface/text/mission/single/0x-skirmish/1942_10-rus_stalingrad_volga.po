msgstr "Seleccione su Doctrina para la misión:"

msgctxt "mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/mission_buys_stay_flag"
msgid "Reinforcement Menu:"
msgstr "Menú de refuerzos:"

msgctxt "mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/buys_on_after_flag"
msgid "Units unlock permanently"
msgstr "Desbloqueo de unidades permanente"

msgctxt "mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/name"
msgid "No Land Behind the Volga!"
msgstr "¡No hay tierra tras el Volga!"

msgctxt "mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/name_big"
msgid "No Land Behind the Volga!"
msgstr "¡No hay tierra tras el Volga!"

msgctxt "mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/story"
msgid "Street fighting, Stalingrad. Take control of the key sectors in the area.\n\nGoals:\n - Gain control of a bridgehead on the Volga.\n - Stop enemy counterattacks."
msgstr ""
"Lucha en la calle,\n"
"Stalingrado#Toma el control de los sectores clave de la zona.\n"
"\n"
"Objetivos:\n"
" - Obtener el control de una cabeza de puente en el Volga.\n"
" - Detener los contraataques enemigos."

msgctxt "mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/place"
msgid "Central Stalingrad, near the banks of the Wolga"
msgstr "El centro de Stalingrado, cerca de las orillas del Wolga"

msgctxt "mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/date"
msgid "October, 1942"
msgstr "Octubre de 1942"

msgctxt ""
"mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/outro_start"
msgid ""
msgstr ""

msgctxt ""
"mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/outro_completed"
msgid ""
"Good job! We now have control over this area. The German vermin shall soon "
"be pushed out of our city!"
msgstr ""
"¡Buen trabajo! Ahora tenemos el control de esta zona. ¡Las alimañas "
"alemanas pronto serán expulsadas de nuestra ciudad!"

msgctxt ""
"mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/outro_failed"
msgid ""
"We failed! How are we to regain control of our city? We have to try again!"
msgstr ""
"Hemos fracasado. ¿Cómo vamos a recuperar el control de nuestra ciudad? "
"¡Tenemos que volver a intentarlo!"

msgctxt ""
"mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/outro_failed_hq"
msgid "Mission failure! - Enemy captured your HQ!"
msgstr "¡Misión fallida! - ¡El enemigo ha capturado tu cuartel general!"

msgctxt ""
"mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/mission_hq"
msgid "You must hold your field HQ!"
msgstr "¡Debes mantener tu cuartel general de campo!"

msgctxt ""
"mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/mission_attack"
msgid "Capture the key buildings!"
msgstr "¡Captura los edificios clave!"

msgctxt ""
"mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/"
"flag_capture_status"
msgid "Your soldiers secured %1%/7 German positions!"
msgstr "¡Tus soldados aseguraron el %1%/7 de las posiciones alemanas!"

msgctxt ""
"mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/narrator_start0"
msgid ""
"Welcome to the city named after our great Leader! This is our field HQ, it "
"must remain in our control!"
msgstr ""
"¡Bienvenidos a la ciudad que lleva el nombre de nuestro gran líder! Este es "
"nuestro cuartel general de campo, ¡debe permanecer bajo nuestro control!"

msgctxt ""
"mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/narrator_start1"
msgid ""
"Comrades, we have to be in control of the flanks if we want to push further "
"into the city. Secure the key locations in the area by eliminating pockets "
"of resistance!"
msgstr ""
"Camaradas, tenemos que controlar los flancos si queremos avanzar en la "
"ciudad. ¡Asegura los lugares clave de la zona eliminando los focos de "
"resistencia!"

msgctxt ""
"mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/narrator_start2"
msgid "Make sure you capture these vital positions!"
msgstr "¡Asegúrate de capturar estas posiciones clave!"

msgctxt ""
"mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/narrator_start3"
msgid ""
"Begin securing your objectives, meanwhile more reinforcements will be "
"brought up for assistance!"
msgstr ""
"Empieza a asegurar tus objetivos, ¡mientras tanto se traerán más refuerzos "
"para ayudar!"

msgctxt ""
"mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/"
"allied_enemy_near_hq"
msgid "Comrades! Germans are close to our Field HQ!"
msgstr ""
"¡Camaradas! ¡Los alemanes están cerca de nuestro cuartel general de campo!"

msgctxt ""
"mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/"
"allied_enemy_plane"
msgid "Enemy plane!!!"
msgstr "¡¡Avión enemigo!!"

msgctxt ""
"mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/"
"player_enemy_near_hq"
msgid ""
"We must hold the command post! There is no room for cowards and traitors in "
"our Red Army!"
msgstr ""
"¡Debemos mantener nuestro puesto de mando! ¡No hay lugar para los cobardes "
"y los traidores en nuestro Ejército Rojo!"

msgctxt "mission/single/01-rus_skirmish/1942_10-rus_stalingrad_volga/hq_bonus"
msgid "Comrade! Now you can request an airstrike."
msgstr "¡Camarada! Ahora puede solicitar un ataque aéreo."
