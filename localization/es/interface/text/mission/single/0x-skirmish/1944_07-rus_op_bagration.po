msgstr "Operación Bagration"

msgctxt "mission/single/01-rus_skirmish/1944_07-rus_op_bagration/name_big"
msgid "Operation Bagration"
msgstr "Operación Bagration"

msgctxt "mission/single/01-rus_skirmish/1944_07-rus_op_bagration/story"
msgid "Belorussian Front, Minsk offensive. After several delays our forces are finally on the move. We will overwhelm the nazis, now that the numbers are stacked in our favor.\n\nGoals:\n - Liberation of Minsk.\n - Destruction of the german Fourth Army."
msgstr ""
"Frente bielorruso,\n"
"Ofensiva de Minsk#Después de varios retrasos nuestras fuerzas están "
"finalmente en\n"
"en movimiento.\n"
"\n"
"Vamos a abrumar a los nazis,\n"
"ahora que los números\n"
"\n"
"están a nuestro favor.\n"
"\n"
"\n"
"Objetivos:\n"
" - Liberación de Minsk.\n"
" - Destrucción del cuarto ejército alemán."

msgctxt "mission/single/01-rus_skirmish/1944_07-rus_op_bagration/place"
msgid "Berezina line"
msgstr "La línea de Berezina"

msgctxt "mission/single/01-rus_skirmish/1944_07-rus_op_bagration/date"
msgid "4 July, 1944"
msgstr "4 de julio de 1944"

msgctxt "mission/single/01-rus_skirmish/1944_07-rus_op_bagration/outro_start"
msgid ""
msgstr ""

msgctxt ""
"mission/single/01-rus_skirmish/1944_07-rus_op_bagration/outro_completed"
msgid "Mission accomplished!"
msgstr "¡Misión cumplida!"

msgctxt "mission/single/01-rus_skirmish/1944_07-rus_op_bagration/outro_failed"
msgid "Mission failure!"
msgstr "¡Misión fallida!"

msgctxt ""
"mission/single/01-rus_skirmish/1944_07-rus_op_bagration/outro_failed_hq"
msgid "Mission failed! - Enemy captured your HQ!"
msgstr "¡Misión fallida! - ¡El enemigo ha capturado tu cuartel general!"

msgctxt "mission/single/01-rus_skirmish/1944_07-rus_op_bagration/mission_hq"
msgid "You must hold your field HQ!"
msgstr "¡Debes mantener tu cuartel general de campo!"

msgctxt ""
"mission/single/01-rus_skirmish/1944_07-rus_op_bagration/mission_attack"
msgid "Capture the river east of Minsk!"
msgstr "¡Captura el río al este de Minsk!"

msgctxt ""
"mission/single/01-rus_skirmish/1944_07-rus_op_bagration/flag_capture_status"
msgid "Your soldiers secured %1%/7 German positions!"
msgstr "¡Tus soldados aseguraron el %1%/7 de las posiciones alemanas!"

msgctxt ""
"mission/single/01-rus_skirmish/1944_07-rus_op_bagration/narrator_start0"
msgid ""
"Welcome to Belarus, Major! This is our field HQ. It has to remain in our "
"control at all times!"
msgstr ""
"¡Bienvenido a Bielorrusia, Mayor! Este es nuestro cuartel general de campo. "
"¡Debe permanecer bajo nuestro control en todo momento!"

msgctxt ""
"mission/single/01-rus_skirmish/1944_07-rus_op_bagration/narrator_start1"
msgid ""
"Comrade, you are tasked with the assault of the enemy defenses in this "
"region and crossing the river. We must capture the German defenses east of "
"Minsk!"
msgstr ""
"Camarada, se te ha encomendado el asalto de las defensas enemigas en esta "
"región y el cruce del río. ¡Debemos capturar las defensas alemanas al este "
"de Minsk!"

msgctxt ""
"mission/single/01-rus_skirmish/1944_07-rus_op_bagration/narrator_start2"
msgid ""
"Germans are planning to reinforce their lines with heavy panzers. Make sure "
"you capture these vital positions!"
msgstr ""
"Los alemanes planean reforzar sus líneas con panzers pesados. ¡Asegúrate de "
"capturar estas posiciones vitales!"

msgctxt ""
"mission/single/01-rus_skirmish/1944_07-rus_op_bagration/narrator_start3"
msgid ""
"Begin securing the objectives, while we bring forward some reinforcements "
"for you to deploy!"
msgstr ""
"Empieza a asegurar los objetivos, ¡mientras traemos algunos refuerzos para "
"que los desplieguen!"

msgctxt ""
"mission/single/01-rus_skirmish/1944_07-rus_op_bagration/allied_enemy_near_hq"
msgid "Comrades! Germans are close to our Field HQ!"
msgstr "¡Camaradas! ¡Los alemanes están cerca de nuestro cuartel general!"

msgctxt ""
"mission/single/01-rus_skirmish/1944_07-rus_op_bagration/player_enemy_near_hq"
msgid "We must hold the command post! There can be no talk of retreat here!"
msgstr ""
"¡Debemos mantener el puesto de mando! ¡No se puede hablar de retirada aquí!"

msgctxt "mission/single/01-rus_skirmish/1944_07-rus_op_bagration/hq_bonus"
msgid "Major! Now you can request an airstrike."
msgstr "¡Mayor! Ahora puede solicitar un ataque aéreo."
