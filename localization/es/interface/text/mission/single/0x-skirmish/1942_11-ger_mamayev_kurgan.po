msgctxt "mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/name"
msgid "Mamayev Kurgan"
msgstr "Mamayev Kurgan"

msgctxt "mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/name_big"
msgid "Mamayev Kurgan"
msgstr "Mamayev Kurgan"

msgctxt "mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/story"
msgid "The battle for Mamayev Kurgan - Battle of Stalingrad. Whoever is in control of Mamayev Kurgan has the advantage of controlling the entire battle. We must take this hill at any price!\n\nGoals:\n - Capture the fortified top of the hill.\n - Fend off counterattacks."
msgstr ""
"La batalla por Mamayev Kurgan\n"
"Batalla de Stalingrado#Quien tenga el control de Mamayev Kurgan\n"
"tiene la ventaja de controlar toda la batalla.\n"
"¡Debemos tomar esta colina a cualquier precio!\n"
"Objetivos:\n"
" - Capturar la cima fortificada de la colina.\n"
" - Evitar los contraataques."

msgctxt "mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/place"
msgid "Stalingrad"
msgstr "Stalingrado"

msgctxt "mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/date"
msgid "September, 1942"
msgstr "Septiembre de 1942"

msgctxt "mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/outro_start"
msgid ""
msgstr ""

msgctxt ""
"mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/outro_completed"
msgid ""
"Mission accomplished! Now we have the fortress on the hill under control we "
"will be able to direct the whole battle from here!"
msgstr ""
"¡Misión cumplida! ¡Ahora que tenemos la fortaleza de la colina bajo control "
"podremos dirigir toda la batalla desde aquí!"

msgctxt ""
"mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/outro_failed"
msgid ""
"Mission failed; this attack will have to be repeated, we cannot allow the "
"soviets keeping control of the hill. You will have to attack again at the "
"first opportunity!"
msgstr ""
"Misión fallida; este ataque tendrá que repetirse, no podemos permitir que "
"los soviéticos mantengan el control de la colina. ¡Tendrán que atacar de "
"nuevo a la primera oportunidad!"

msgctxt ""
"mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/outro_failed_hq"
msgid "Mission failure! - Enemy captured your HQ!"
msgstr "¡Misión fallida! - ¡El enemigo ha capturado tu cuartel general!"

msgctxt "mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/mission_hq"
msgid "You must hold your field HQ!"
msgstr "¡Debes mantener tu cuartel general de campo!"

msgctxt ""
"mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/mission_attack"
msgid "Capture the river east of Minsk!"
msgstr "¡Captura el río al este de Minsk!"

msgctxt ""
"mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/flag_capture_status"
msgid "Your soldiers secured %1%/7 Soviet positions!"
msgstr "¡Tus soldados aseguraron el %1%/7 de las posiciones soviéticas!"

msgctxt ""
"mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/narrator_start0"
msgid ""
"Welcome to battle, Major! This is our field HQ, it must remain in our "
"control!"
msgstr ""
"¡Bienvenido a la batalla, Mayor! Este es nuestro cuartel general de campo, "
"¡debe permanecer bajo nuestro control!"

msgctxt ""
"mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/narrator_start1"
msgid ""
"Comrade, you are tasked with assault of enemy defenses and crossing the "
"river. Finally we must capture Soviet defenses east of Minsk!"
msgstr ""
"Camarada, tienes la tarea de asaltar las defensas enemigas y cruzar el río. "
"¡Finalmente debemos capturar las defensas soviéticas al este de Minsk!"

msgctxt ""
"mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/narrator_start2"
msgid ""
"Soviets are planning reinforce their lines with heavy Tanks. Make sure you "
"capture these vital positions!"
msgstr ""
"Los soviéticos están planeando reforzar sus líneas con tanques pesados. "
"¡Asegúrate de capturar estas posiciones vitales!"

msgctxt ""
"mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/narrator_start3"
msgid ""
"Begin securing the objectives, meanwhile more reinforcements are being "
"prepared at your disposal!"
msgstr ""
"Comienza a asegurar los objetivos, ¡mientras tanto se preparan más refuerzos "
"a tu disposición!"

msgctxt ""
"mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/"
"allied_enemy_near_hq"
msgid "Comrades! Soviets are close to our Field HQ!"
msgstr "¡Camaradas! ¡Los soviéticos están cerca de nuestro cuartel general!"

msgctxt ""
"mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/"
"player_enemy_near_hq"
msgid ""
"We must hold the command post! There is no room for cowards and traitors in "
"our Red Army!"
msgstr ""
"¡Debemos mantener nuestro puesto de mando! ¡No hay lugar para los cobardes y "
"los traidores en nuestro Ejército Rojo!"

msgctxt ""
"mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/allied_enemyarty"
msgid "Soviet artillery inbound from across the Volga river!"
msgstr "¡La artillería soviética se acerca desde el otro lado del río Volga!"

msgctxt "mission/single/02-ger_skirmish/1942_11-ger_mamayev_kurgan/hq_bonus"
msgid "Major! Now you can request an airstrike."
msgstr "¡Mayor! Ahora puede solicitar un ataque aéreo."
