msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/name"
msgid "Battle of Smolensk"
msgstr "Batalla de Smolensk"

msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/name_big"
msgid "Battle of Smolensk"
msgstr "Batalla de Smolensk"

msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/story"
msgid " East of Smolensk, relief offensive. After the initial battles, you're surrounded by Germans. Time for a breakout attempt!\n\nGoals:\n - Break the encirclement of the 20th army.\n - Close the front east of Kiev."
msgstr ""
"Este de Smolensk,\n"
"ofensiva de relevo#Después de las batallas iniciales, estás rodeado de "
"alemanes.\n"
"\n"
"¡Es hora de un intento de fuga!\n"
"\n"
"Objetivos:\n"
" - Romper el cerco del 20º ejército.\n"
" - Cerrar el frente al este de Kiev."

msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/place"
msgid "East of Smolensk"
msgstr "Este de Smolensk"

msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/date"
msgid "21 July, 1941"
msgstr "21 de julio de 1941"

msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/outro_start"
msgid ""
msgstr ""

msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/outro_completed"
msgid "Well done! we have established contact with the trapped armies!"
msgstr "¡Bien hecho! ¡Hemos establecido contacto con los ejércitos atrapados!"

msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/outro_failed"
msgid ""
"We haven't been able to relieve the trapped armies, and since we lost a lot "
"of equipment we will need to fall back to the east!"
msgstr ""
"No hemos podido relevar a los ejércitos atrapados, ¡y como hemos perdido "
"mucho equipo tendremos que retroceder hacia el este!"

msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/outro_failed_hq"
msgid ""
"We lost the chance to open a corridor through which no less than 3 armies "
"could have been saved. A black day in soviet history."
msgstr ""
"Perdimos la oportunidad de abrir un corredor a través del cual se podrían "
"haber salvado al menos 3 ejércitos. Un día negro en la historia soviética."

msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/mission_hq"
msgid "You must hold your field HQ!"
msgstr "¡Debes mantener tu cuartel general de campo!"

msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/mission_attack"
msgid "Punch a hole in the enemy position and drive west!"
msgstr "¡Haz un agujero en la posición del enemigo y ve hacia el oeste!"

msgctxt ""
"mission/single/01-rus_skirmish/1941_07-rus_smolensk/flag_capture_status"
msgid "Your soldiers secured %1%/7 German positions!"
msgstr "¡Tus soldados aseguraron el %1%/7 de las posiciones alemanas!"

msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/narrator_start0"
msgid ""
"Welcome to battle, Major! This is our field HQ, it must remain in our "
"control!"
msgstr ""
"¡Bienvenido a la batalla, Mayor! Este es nuestro cuartel general de campo, "
"¡debe permanecer bajo nuestro control!"

msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/narrator_start1"
msgid ""
"Comrade, there is no choice but to attack immediately. Orders from the "
"Kommisar were quite clear, you can't afford to postpone the attack!"
msgstr ""
"Camarada, no hay otra opción que atacar inmediatamente. Las órdenes del "
"Kommisar fueron muy claras, ¡no puedes permitirte posponer el ataque!"

msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/narrator_start2"
msgid ""
"The germans will not expect us to attack from this direction, they are "
"focused on eliminating the Smolensk garrison!"
msgstr ""
"Los alemanes no esperan que ataquemos desde esta dirección, ¡están "
"concentrados en eliminar la guarnición de Smolensk!"

msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/narrator_start3"
msgid ""
"Begin the attack, meanwhile more reinforcements are being prepared for your "
"disposal!"
msgstr ""
"Comienza el ataque, ¡mientras tanto se preparan más refuerzos a tu "
"disposición!"

msgctxt ""
"mission/single/01-rus_skirmish/1941_07-rus_smolensk/allied_enemy_near_hq"
msgid "Comrades! Germans are close to our Field HQ!"
msgstr "¡Camaradas! ¡Los alemanes están cerca de nuestro cuartel general!"

msgctxt ""
"mission/single/01-rus_skirmish/1941_07-rus_smolensk/allied_enemy_plane"
msgid "Enemy plane!!!"
msgstr "¡¡Avión enemigo!!"

msgctxt ""
"mission/single/01-rus_skirmish/1941_07-rus_smolensk/allied_enemy_plane2"
msgid "German aircraft inbound!"
msgstr "¡Avión alemán en camino!"

msgctxt ""
"mission/single/01-rus_skirmish/1941_07-rus_smolensk/player_enemy_near_hq"
msgid ""
"We must hold our command post! There is no room for cowards and traitors in "
"our Red Army!"
msgstr ""
"¡Debemos mantener nuestro puesto de mando! ¡No hay lugar para los cobardes y "
"los traidores en nuestro Ejército Rojo!"

msgctxt "mission/single/01-rus_skirmish/1941_07-rus_smolensk/hq_bonus"
msgid "Major! Now you can request an airstrike."
msgstr "¡Mayor! Ahora puede solicitar un ataque aéreo."
