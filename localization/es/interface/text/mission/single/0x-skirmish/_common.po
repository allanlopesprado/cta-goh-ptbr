msgctxt "mission/single/0x-skirmish/arty_bad_location"
msgid ""
"The location you marked for artillery is out of range for targeting. Please "
"call-in artillery on a new location!"
msgstr ""
"La ubicación que marcaste para la artillería está fuera del alcance para "
"atacar. ¡Indica otra ubicación!"

msgctxt "mission/single/0x-skirmish/arty_called"
msgid "Keep your heads down! Our artillery guns are opening fire!"
msgstr "¡Al suelo! ¡Nuestra artillería está abriendo fuego!"
