msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/story"
msgid " Arctic front, the push for Murmansk. We have covered a lot of ground with our flanking attack. But the village ahead seems heavily defended. You need to attack immediately!\n\nGoals:\n - Destroy Soviet armor.\n - Take Alakurtti."
msgstr ""
"El frente ártico,\n"
"el empuje hacia Murmansk# Hemos cubierto mucho terreno con nuestro\n"
"ataque de flanqueo. Pero el pueblo por delante parece\n"
"fuertemente defendido. ¡Ataca inmediatamente!\n"
"\n"
"Objetivos:\n"
" - Destruir el blindaje soviético.\n"
" - Tomar Alakurtti."

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/place"
msgid "Alakurtti, Murmansk region"
msgstr "Alakurtti, región de Murmansk"

msgctxt "mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/date"
msgid "July, 1941"
msgstr "Julio de 1941"

msgctxt ""
"mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/outro_start"
msgid ""
msgstr ""

msgctxt ""
"mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/"
"outro_completed"
msgid "Mission accomplished!"
msgstr "¡Misión cumplida!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/outro_failed"
msgid "Mission failed!"
msgstr "¡Misión fallida!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/"
"outro_failed_hq"
msgid "Mission failed! - your HQ was taken!"
msgstr "¡Misión fallida! - ¡Su cuartel general fue tomado!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/mission_hq"
msgid "You have to hold your field HQ!"
msgstr "¡Tienes que mantener tu cuartel general de campo!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/"
"mission_attack"
msgid "Attack the village of Alakurtti!"
msgstr "¡Ataca el pueblo de Alakurtti!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/"
"flag_capture_status"
msgid "Your soldiers secured %1%/7 Soviet positions!"
msgstr "¡Tus soldados aseguraron el %1%/7 de las posiciones soviéticas!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/"
"narrator_start0"
msgid ""
"Welcome to the Murmansk regional HQ, Major! It has to remain in our control "
"at all times!"
msgstr ""
"¡Bienvenido al cuartel regional de Murmansk, Mayor! ¡Tiene que permanecer "
"en nuestro control en todo momento!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/"
"narrator_start1"
msgid ""
"Comrade, you are tasked with performing a decisive push toward Murmansk! "
"Take the village of Alakurtti!"
msgstr ""
"¡Camarada, tienes la tarea de realizar un empuje decisivo hacia Murmansk! "
"¡Toma el pueblo de Alakurtti!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/"
"narrator_start2"
msgid ""
"The Soviets may reinforce their lines with heavy armor. Make sure you move "
"before they get here!"
msgstr ""
"Los soviéticos pueden reforzar sus líneas con blindaje pesado. ¡Asegúrate "
"de moverte antes de que lleguen!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/"
"narrator_start3"
msgid ""
"Begin securing the objectives, while we bring forward some reinforcements "
"for you to deploy!"
msgstr ""
"Empieza a asegurar los objetivos, ¡mientras traemos algunos refuerzos para "
"que los desplieguen!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/"
"allied_enemy_near_hq"
msgid "Asetoverit! Soviets are close to our Field HQ!"
msgstr "¡Asetoverit! ¡Los soviéticos están cerca de nuestro cuartel general!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/"
"player_enemy_near_hq"
msgid "We must hold the command post! There can be no talk of retreat here!"
msgstr "We must hold the command post! There can be no talk of retreat here!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_08-fin_polar_fox_alakurtti/hq_bonus"
msgid "Major! Now you can request an airstrike."
msgstr "¡Mayor! Ahora puede solicitar un ataque aéreo."
