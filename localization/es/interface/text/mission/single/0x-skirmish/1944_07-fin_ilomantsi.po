msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/story"
msgid "Karelian Front, Svir–Petrozavodsk offensive. On the Soviet side, an offensive seems to build it's obvious what's coming let's be ahead of them!\n\nGoals:\n - Stop the enemy attack before it starts.\n - Use Motti tactics to defeat the enemy."
msgstr ""
"Frente de Carelia,\n"
"Svir-Petrozavodsk ofensiva#En el lado soviético, una ofensiva parece "
"construirse\n"
"Es obvio lo que viene, ¡adelantémonos a ellos!\n"
"\n"
"\n"
"\n"
"Objetivos:\n"
" - Detener el ataque inicial antes de que comience.\n"
" - Utilizar las tácticas de Motti para derrotar al enemigo."

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/place"
msgid "Ilomantsi"
msgstr "Ilomantsi"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/date"
msgid "July, 1944"
msgstr "Julio de 1944"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/outro_start"
msgid ""
msgstr ""

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/outro_completed"
msgid "Mission accomplished!"
msgstr "¡Misión cumplida!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/outro_failed"
msgid "Mission failure!"
msgstr "¡Misión fallida!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/outro_failed_hq"
msgid "Mission failed! - The enemy captured your HQ!"
msgstr "¡Misión fallida! - ¡El enemigo ha capturado tu cuartel general!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/mission_hq"
msgid "You must hold your field HQ!"
msgstr "¡Debes mantener tu cuartel general de campo!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/mission_attack"
msgid "Hold the position at all costs!"
msgstr "¡Mantén la posición a toda costa!"

msgctxt ""
"mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/flag_capture_status"
msgid "Your soldiers secured %1%/7 Soviet positions!"
msgstr "¡Tus soldados aseguraron el %1%/7 de las posiciones soviéticas!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/narrator_start0"
msgid ""
"Welcome to your North Karelia HQ, Major! This is the one place that has to remain "
"in our control at all times."
msgstr ""
"¡Bienvenido a su Cuartel General de Carelia del Norte, Mayor! Este es el "
"único lugar que debe permanecer bajo nuestro control en todo momento."

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/narrator_start1"
msgid ""
"You will attack the enemy starting points to pre- empt his large- scale "
"offensive. Break the enemy columns up in groups and destroy them!"
msgstr ""
"Atacarás los puntos de partida del enemigo para prevenir su ofensiva a gran "
"escala. ¡Rompe las columnas enemigas en grupos y destrúyelas!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/narrator_start2"
msgid "The enemy is bringing heavy units forward. Call the air force!"
msgstr ""
"El enemigo está trayendo unidades pesadas hacia adelante. ¡Llama a la fuerza "
"aérea!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/narrator_start3"
msgid ""
"Keep the enemy on the defensive, while we get some reinforcements for you to "
"deploy!"
msgstr ""
"¡Mantengan al enemigo a la defensiva, mientras conseguimos algunos refuerzos "
"para que los desplieguen!"

msgctxt ""
"mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/allied_enemy_near_hq"
msgid "Asetoverit! Soviets are close to our Field HQ!"
msgstr "¡Asetoverit! ¡Los soviéticos están cerca de nuestro cuartel general!"

msgctxt ""
"mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/allied_enemy_plane"
msgid "Asetoverit! Soviet plane attacking!"
msgstr "¡Asetoverit! ¡Avión soviético atacando!"

msgctxt ""
"mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/player_enemy_near_hq"
msgid "We must hold the command post! There can be no talk of retreat here!"
msgstr ""
"¡Debemos mantener el puesto de mando! ¡No se puede hablar de retirada aquí!"

msgctxt "mission/single/03-fin_skirmish/1944_07-fin_ilomantsi/hq_bonus"
msgid "Major! Now you can request an airstrike."
msgstr "¡Mayor! Ahora puede solicitar un ataque aéreo."
