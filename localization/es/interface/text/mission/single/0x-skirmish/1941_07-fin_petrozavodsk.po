msgid ""
msgstr ""

msgctxt ""
"mission/single/03-fin_skirmish/1941_07-fin_petrozavodsk/outro_completed"
msgid "Mission accomplished!"
msgstr "¡Misión cumplida!"

msgctxt "mission/single/03-fin_skirmish/1941_07-fin_petrozavodsk/outro_failed"
msgid "Mission failure!"
msgstr "¡Misión fallida!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_07-fin_petrozavodsk/outro_failed_hq"
msgid "Mission failed! - Enemy captured your HQ!"
msgstr "¡Misión fallida! - ¡El enemigo ha capturado tu cuartel general!"

msgctxt "mission/single/03-fin_skirmish/1941_07-fin_petrozavodsk/mission_hq"
msgid "You must hold your field HQ!"
msgstr "¡Debes mantener tu cuartel general de campo!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_07-fin_petrozavodsk/mission_attack"
msgid "Set up a roadblock on the south escape from Petrozavodsk!"
msgstr "¡Prepara un control de carretera en la salida sur de Petrozavodsk!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_07-fin_petrozavodsk/flag_capture_status"
msgid "Your soldiers secured %1%/7 Soviet positions!"
msgstr "¡Tus soldados aseguraron el %1%/7 de las posiciones soviéticas!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_07-fin_petrozavodsk/narrator_start0"
msgid ""
"Welcome to East Karelia, Major! This is your new field HQ. It must remain in "
"your control at all cost!"
msgstr ""
"¡Bienvenido a Carelia Oriental, Mayor! Este es su nuevo cuartel general de "
"campo. ¡Debe permanecer bajo su control a toda costa!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_07-fin_petrozavodsk/narrator_start1"
msgid ""
"Comrade, you are tasked with cutting the enemy off from escape. After that, "
"you must destroy the defending forces!"
msgstr ""
"Camarada, tienes la tarea de cortar el escape del enemigo. Después de eso, "
"¡debes destruir las fuerzas defensoras!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_07-fin_petrozavodsk/narrator_start2"
msgid "Set up a roadblock and create a \"Motti\" battleground!"
msgstr "¡Prepara una barricada y crea un campo de batalla \"Motti\"!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_07-fin_petrozavodsk/narrator_start3"
msgid ""
"Begin securing the objectives, while we bring forward some reinforcements "
"for you to deploy!"
msgstr ""
"Empieza a asegurar los objetivos. ¡Mientras traemos algunos refuerzos para "
"que los desplieguen!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_07-fin_petrozavodsk/allied_enemy_near_hq"
msgid "Asetoverit! Soviets are threatening our Field HQ!"
msgstr "¡Asetoverit! ¡Los soviéticos están amenazando nuestro cuartel general!"

msgctxt ""
"mission/single/03-fin_skirmish/1941_07-fin_petrozavodsk/allied_capture_t34"
msgid "Look! There's an abandoned T-34 tank. We may be able to repair it."
msgstr "¡Mira! Hay un tanque T-34 abandonado. Tal vez podamos repararlo."

msgctxt ""
"mission/single/03-fin_skirmish/1941_07-fin_petrozavodsk/player_enemy_near_hq"
msgid "Hold the command post! There can be no talk of retreat here!"
msgstr "¡Mantengan el puesto de mando! ¡Aquí no se puede hablar de retirada!"

msgctxt "mission/single/03-fin_skirmish/1941_07-fin_petrozavodsk/hq_bonus"
msgid "Major! Now you can request an airstrike."
msgstr "¡Mayor! Ahora puede solicitar un ataque aéreo."
