msgid "Units unlock permanently"
msgstr "Desbloqueo de unidades permanente"

msgctxt "mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/name"
msgid "Bloodshed at the Seelow Heights"
msgstr "Derramamiento de sangre en las Colinas de Seelow"

msgctxt "mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/name_big"
msgid "Bloodshed at the Seelow Heights"
msgstr "Derramamiento de sangre en las Colinas de Seelow"

msgctxt "mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/story"
msgid "Seelow heights, Oderbruch Offensive. The attack is about to begin. As usual, there will be a big artillery bombardment. Attack as soon as possible!\n\nGoals:\n - Clear the way to Berlin.\n - Destruction of the German 9th Army."
msgstr ""
"Las colinas de Seelow,\n"
"Operación Ofensiva Estratégica#El ataque está a punto de comenzar. Como es "
"habitual,\n"
"habrá un gran bombardeo de artillería.\n"
"¡Ataquen lo antes posible!\n"
"\n"
"Objetivos:\n"
" - Despejar el camino a Berlín.\n"
" - Destrucción del 9º Ejército alemán."

msgctxt "mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/place"
msgid "Seelow, Germany"
msgstr "Seelow, Germany"

msgctxt "mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/date"
msgid "April, 1945"
msgstr "Abril de 1945"

msgctxt "mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/outro_start"
msgid ""
msgstr ""

msgctxt ""
"mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/outro_completed"
msgid "Victory! The road to Berlin is now open. Good job!"
msgstr "¡Victoria! El camino a Berlín está abierto. ¡Buen trabajo!"

msgctxt ""
"mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/outro_failed"
msgid ""
"Mission failed; enemy resistance was too much. We will have to try again!"
msgstr ""
"Misión fallida; la resistencia del enemigo era demasiado. ¡Tendremos que "
"volver a intentarlo!"

msgctxt ""
"mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/outro_failed_hq"
msgid "Mission failed! - The enemy captured our HQ!"
msgstr "¡Misión fallida! - ¡El enemigo ha capturado tu cuartel general!"

msgctxt "mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/mission_hq"
msgid "You must hold your field HQ!"
msgstr "¡Debes mantener tu cuartel general de campo!"

msgctxt ""
"mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/mission_attack"
msgid "Break through the Seelow Heights"
msgstr "Atraviesa las colinas de Seelow"

msgctxt ""
"mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/flag_capture_status"
msgid "Your soldiers secured %1%/7 German positions!"
msgstr "¡Tus soldados aseguraron el %1%/7 de las posiciones alemanas!"

msgctxt ""
"mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/narrator_start0"
msgid ""
"You are now on the lair of the Beast! This is our field HQ, it must remain "
"in our control!"
msgstr ""
"¡Están ahora en la guarida de la Bestia! Este es nuestro cuartel general de "
"campo, ¡debe permanecer bajo nuestro control!"

msgctxt ""
"mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/narrator_start1"
msgid ""
"Comrade, you are tasked with breaching through these heavily defended "
"heights. We must crush the Seelow defenses and drive on to Berlin!"
msgstr ""
"Camarada, tu tarea es atravesar estas colinas fuertemente defendidas. "
"¡Debemos aplastar las defensas de Seelow y avanzar hacia Berlín!"

msgctxt ""
"mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/narrator_start2"
msgid ""
"The germans are planning to reinforce their lines with everything they've "
"got! Make sure to flank them and overwhelm them with our numbers!"
msgstr ""
"¡Los alemanes están planeando reforzar sus líneas con todo lo que tienen! "
"¡Asegúrate de flanquearlos y abrumarlos con nuestros números!"

msgctxt ""
"mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/narrator_start3"
msgid "Begin securing the objectives, you will get some reinforcements soon!"
msgstr "Comienza a asegurar los objetivos, ¡pronto recibirás refuerzos!"

msgctxt ""
"mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/"
"allied_enemy_near_hq"
msgid "Comrades! Germans are sneaking up on our Field HQ!"
msgstr ""
"¡Camaradas! ¡Los alemanes están cerca de nuestro cuartel general de campo!"

msgctxt ""
"mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/"
"player_enemy_near_hq"
msgid ""
"We must hold this command post at all costs, or ruin the coordination of an "
"entire army!"
msgstr ""
"¡Debemos mantener este puesto de mando a toda costa, o arruinar la "
"coordinación de todo un ejército!"

msgctxt "mission/single/01-rus_skirmish/1945_04-rus_seelow_heights/hq_bonus"
msgid "Comrade! Now you can request an airstrike."
msgstr "¡Camarada! Ahora puede solicitar un ataque aéreo."
