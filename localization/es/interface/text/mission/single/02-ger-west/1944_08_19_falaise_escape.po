msgctxt "mission/single/02-ger-west/1944_08_19_falaise_escape/date"
msgid "August 19th, 1944 · Magny, Normandy, France"
msgstr "19 de agosto, 1944 - Magny, Normandía, Francia"

msgctxt ""
"mission/single/02-ger-west/1944_08_19_falaise_escape/doctrine_allround"
msgid "Doctrine: All-Round"
msgstr "Doctrina: Completa"

msgctxt ""
"mission/single/02-ger-west/1944_08_19_falaise_escape/doctrine_defensive"
msgid "Doctrine: Defensive"
msgstr "Doctrina: Defensiva"

