msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/date"
msgid "June 12th, 1944 · Carentan, Normandy, France."
msgstr "12 de junio de 1944. Carentan, Normandía, Francia."

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/lose_winters"
msgid "Lt. Winters is dead!"
msgstr "¡El teniente Winters ha muerto!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/name"
msgid "The Eagles and the Devils"
msgstr "\"Eagles\" y \"Devils\""

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/name_big"
msgid "The Eagles and the Devils"
msgstr "\"Eagles\" y \"Devils\""

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator02"
msgid "Move men! Get out of the ditch! Go!"
msgstr "¡Moveos, muchachos! ¡Salid de la zanja! ¡Vamos!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator03"
msgid ""
"The crossroads are secure! Move north along the road to the center of town. "
"Let's move out!"
msgstr ""
"¡La encrucijada está asegurada! Avanza hacia el norte por la carretera hasta "
"el centro de la ciudad ¡Vamos!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator04"
msgid "We've got no cover here! Move! Move!"
msgstr "¡Aquí no tenemos cobertura! ¡Moveos! ¡Moveos!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator05"
msgid "We need to hit those mortars fast, or they'll rip us apart!"
msgstr "¡Tenemos que atacar rápido a esos morteros o nos van a destrozar!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator06"
msgid "Look alive! A fresh squad here to join the fight."
msgstr "¡No desfallezcáis! Tenemos un nuevo grupo con nosotros."

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator07"
msgid "Left flank is clear!"
msgstr "¡Flanco izquierdo despejado!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator08"
msgid "Gardens on the right are secure!"
msgstr "¡Los jardines de la derecha son seguros!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator09"
msgid ""
"We have managed to clear everything south of this railway! We've observed "
"enemy movement in the town, they appear to be preparing to counterattack."
msgstr ""
"¡Despejado todo al sur de estas vías del tren. Hemos observado movimiento "
"enemigo en la ciudad, parece que se preparan para contraatacar."

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator10"
msgid ""
"Our Weapons Platoon has caught up to us. Get them set in and prepare to "
"defend our position."
msgstr ""
"El pelotón de armas por fin ha llegado. Que se posicionen y se preparen para "
"defender nuestra posición."

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator11"
msgid "Enemy mortars! Take cover!"
msgstr "¡Morteros enemigos! ¡A cubierto!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator13"
msgid "Friendly glider troops coming from the North-West!"
msgstr "¡Vienen tropas aliadas de los planeadores, desde el noroeste!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator14"
msgid "Kraut Halftrack!"
msgstr "¡Semioruga boche!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator15"
msgid "Go, go, go!"
msgstr "¡Vamos, vamos, vamos!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator17"
msgid "Be careful with that, Trooper!"
msgstr "¡Ten cuidado con eso, soldado!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator18"
msgid ""
"We've got orders to set up defenses on the high ground to the west of town. "
"We're not going to wait around here for another counterattack."
msgstr ""
"Tenemos órdenes de establecer defensas en el terreno elevado al oeste de la "
"ciudad. No vamos a esperar aquí otro contraataque."

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator19"
msgid ""
"Well you just take it easy, Lip. We'll get you out of here and back to "
"England."
msgstr "Tranquilo, Lip. Te sacaremos de aquí y volverás a Inglaterra."

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/narrator_lipton01"
msgid "Don't worry about me, Sir. I'll be back before long."
msgstr "No se preocupe por mí, señor. No tardaré en volver."

msgctxt ""
"mission/single/041-usa_airborne/1944_06_05_carentan/narrator_soldier01"
msgid "It seems quiet, Sir."
msgstr "Parece tranquilo, señor."

msgctxt ""
"mission/single/041-usa_airborne/1944_06_05_carentan/narrator_soldier02"
msgid "Look, Sir! They're pulling back!"
msgstr "¡Mire, señor! ¡Están retrocediendo!"

msgctxt ""
"mission/single/041-usa_airborne/1944_06_05_carentan/narrator_soldier03"
msgid "Jerry is retreating again!"
msgstr "¡Los alemanes se retiran de nuevo!"

msgctxt ""
"mission/single/041-usa_airborne/1944_06_05_carentan/narrator_soldier04"
msgid "Those Krauts have had enough!"
msgstr "¡Parece que los alemanes han tenido suficiente!"

msgctxt ""
"mission/single/041-usa_airborne/1944_06_05_carentan/narrator_soldier05"
msgid "Hey, check this out! Jerry was too busy runnin’ to take this with ‘em!"
msgstr ""
"Eh, ¡mira esto! ¡Los boches estaban demasiado ocupados corriendo que se "
"olvidaron llevarse esto con ellos!"

msgctxt ""
"mission/single/041-usa_airborne/1944_06_05_carentan/narrator_soldier06"
msgid "This area of town is secure! What do we have planned next, Sir?"
msgstr "¡Esta zona de la ciudad es segura! ¿Qué tiene planeado, señor?"

msgctxt ""
"mission/single/041-usa_airborne/1944_06_05_carentan/narrator_soldier07"
msgid "Take cover! Enemy machine gun!"
msgstr "¡A cubierto! ¡Ametralladora enemiga!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/outro_completed"
msgid ""
"Well done! With Carentan secured, our forces at Omaha and Utah are now "
"linked. With this continuous beachhead, our forces can break out and take "
"control of the Cotentin peninsula."
msgstr ""
"¡Bien hecho! Con Carentan asegurado, nuestras fuerzas en Omaha y Utah están "
"ahora unidas. Con esta cabeza de playa, nuestras fuerzas pueden salir y "
"tomar el control de la península de Cotentin."

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/outro_failed"
msgid ""
"We failed! Carentan remains in German hands, preventing our forces on Utah "
"and Omaha beaches from linking up. You must try again!"
msgstr ""
"¡Hemos fracasado! Carentan sigue en manos alemanas, impidiendo el enlace de "
"nuestras fuerzas en las playas de Utah y Omaha ¡Debes intentarlo de nuevo!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/place"
msgid "101st Airborne Division \"Screaming Eagles\""
msgstr "101ª División Aerotransportada \"Screaming Eagles\""

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/situation1"
msgid "D-Day +6, 06:00h"
msgstr "Día D +6, 06:00h"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/story"
msgid ""
"  It's been almost a week since you parachuted into France, and it’s been "
"one hell of a week. The Germans are not ready to give up Normandy, and "
"several fierce counterattacks have proven that this battle is far from "
"over.\n"
"\n"
"  It’s clear that whoever holds Carentan, holds the key to the Cotentin "
"peninsula. If the 101st takes Carentan, our Utah and Omaha Beach forces can "
"unite to form a continuous front.\n"
"\n"
"  Your regiment, the 506th PIR, will approach Carentan from the south. Your "
"orders are to take the Carentan railway station. In support of your push, "
"the 401st Glider Infantry Regiment will attack from the opposite side of "
"town.\n"
"\n"
" Good luck!"
msgstr ""
"  Ha pasado casi una semana desde que te lanzaste en paracaídas sobre la "
"Francia ocupada y ha sido una semana infernal. Los alemanes no están "
"dispuestos a renunciar a Normandía y varios contraataques muy feroces han "
"demostrado que esta batalla está lejos de terminar.\n"
"\n"
"  Está claro que quien controle Carentan, tendrá la llave de la península de "
"Cotentin. Si la 101 toma Carentan, nuestras fuerzas de Utah y Omaha podrán "
"juntarse y formar un frente continuo.\n"
"\n"
"  Tu regimiento, el 506º PIR, se acercará a Carentan desde el sur. Tus "
"órdenes son tomar la estación de ferrocarril de Carentan. En apoyo de tu "
"ataque, el 401º Regimiento de Infantería de Planeadores atacará desde el "
"lado opuesto de la ciudad.\n"
"\n"
" ¡Mucha suerte!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/task1"
msgid "Neutralize the enemy MG42 and clear the crossroads!"
msgstr "¡Neutraliza la MG42 enemiga y despeja la encrucijada!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/task2"
msgid "Clear the road heading to the center of Carentan!"
msgstr "¡Despeja la carretera que se dirige al centro de Carentan!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/task3"
msgid "Neutralize enemy mortars in the gardens!"
msgstr "¡Neutraliza los morteros enemigos en los jardines!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/task4"
msgid "Prepare to defend your position!"
msgstr "¡Prepárate para defender tu posición!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/task5"
msgid "Defend your position until reinforcements arrive!"
msgstr "¡Defiende tu posición hasta que lleguen los refuerzos!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/task6"
msgid "Neutralize enemy mortars in the town!"
msgstr "¡Neutraliza los morteros enemigos en la ciudad!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/task7"
msgid "Link up with allied glider troops and capture enemy HQ!"
msgstr ""
"¡Únete a las tropas aliadas de los planeadores y captura el cuartel general "
"enemigo!"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/task_secret"
msgid "Secret Objective #1"
msgstr "Objetivo secreto nº 1"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/task_secret_comp"
msgid "(Secret Objective #1) Find the German rocket artillery."
msgstr "(Objetivo secreto nº 1) Encuentra la artillería de cohetes alemana."

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/task_winters"
msgid "Lt. Winters must survive."
msgstr "El teniente Winters debe sobrevivir."

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/timer"
msgid "Prepare for an enemy counterattack:"
msgstr "Prepárate para un contraataque enemigo:"

msgctxt "mission/single/041-usa_airborne/1944_06_05_carentan/timer2"
msgid "Defend your position!"
msgstr "¡Defiende tu posición!"
