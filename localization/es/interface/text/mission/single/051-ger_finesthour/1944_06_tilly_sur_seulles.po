msgctxt "mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/name"
msgid "Against the Tide [SKIRMISH]"
msgstr "Contra corriente [ESCARAMUZA]"

msgctxt "mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/name_big"
msgid "Against the Tide"
msgstr "Contra corriente"

msgctxt "mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/story"
msgid ""
"So far, the Germans have not been able to drive the Allies back into the sea"
msgstr ""
"Hasta ahora, los alemanes no han sido capaces de empujar a los aliados de "
"vuelta al mar."

msgctxt "mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/place"
msgid "Panzer-Lehr Division, Panzer Corps"
msgstr "División Panzer-Lehr, Cuerpo Panzer"

msgctxt "mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/date"
msgid "June 12th, 1944 · Tilly-sur-Seulles, Normandy, France"
msgstr "12 de junio de 1944 · Tilly-sur-Seulles, Normandía, Francia"

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/outro_start"
msgid ""
msgstr ""

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/outro_completed"
msgid ""
"That will show them! We have dealt the British a serious blow, and your "
"leadership was a large part of this success. This opens up new possibilities "
"to drive the Allies back onto the beaches, well done!"
msgstr ""
"¡Eso les enseñará! Hemos asestado un duro golpe a los británicos, y tu "
"liderazgo ha sido fundamental para este éxito. Esto abre nuevas "
"posibilidades para hacer retroceder a los aliados hacia las playas. ¡Bien "
"hecho!"

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/outro_failed"
msgid ""
"Who’s going to tell Field Marshal Rommel? This was our chance to breach the "
"allied lines and push them back. Instead, British armor has broken through. "
"Now we must plan a renewed attempt to stop them."
msgstr ""
"¿Quién se lo va a decir al mariscal de campo Rommel? Esta era nuestra "
"oportunidad para romper las líneas aliadas y hacerlos retroceder. En cambio, "
"las fuerzas blindadas británicas han logrado abrirse paso. Ahora debemos "
"planear un nuevo intento para detenerlos."

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/outro_failed_hq"
msgid "Mission failed - That borders on disaster!"
msgstr "Misión fallida: ¡eso roza el desastre!"

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/mission_hq"
msgid "You must hold your field HQ!"
msgstr "¡Debes mantener tu cuartel general de campo!"

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/mission_extra"
msgid "Shot down British recon plane!"
msgstr "¡Derribado avión de reconocimiento británico!"

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/mission_attack"
msgid "Advance north of Tilly-sur-Seulles road and drive the Allies out!"
msgstr ""
"¡Avanza hacia el norte por la carretera de Tilly-sur-Seulles y expulsa a los "
"aliados!"

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/"
"flag_capture_status"
msgid "Your soldiers secured %1%/7 British positions!"
msgstr "¡Tus soldados han asegurado %1%/7 posiciones británicas!"

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/narrator_start0"
msgid ""
"Welcome to Tilly-sur-Seulles, Major! This is your field HQ, make sure keep "
"it secure!"
msgstr ""
"¡Bienvenido a Tilly-sur-Seulles, comandante! Este es tu cuartel general de "
"campaña, ¡asegúrate de mantenerlo a salvo!"

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/narrator_start1"
msgid ""
"You need to attack! Use the superiority of your armor to achieve vicotry. "
"Punch a hole through the British lines."
msgstr ""
"¡Tienes que atacar! Aprovecha la superioridad de tu armadura para alcanzar "
"la victoria. Abre una brecha en las líneas británicas."

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/narrator_start2"
msgid ""
"Be quick, be decisive, and try not to lose too many men! Use the terrain to "
"your advantage."
msgstr ""
"¡Sé rápido, sé decisivo y trata de no perder demasiados hombres! Aprovecha "
"el terreno a tu favor."

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/narrator_start3"
msgid ""
"More reinforcements will become available as you progress with your assault!"
msgstr ""
"¡A medida que avances en tu asalto, tendrás más refuerzos a tu disposición!"

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/"
"allied_enemy_near_hq"
msgid "Major! British are close to our Field HQ!"
msgstr ""
"¡Comandante! ¡Los británicos están cerca de nuestro cuartel general de "
"campaña!"

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/"
"allied_enemy_plane"
msgid "Enemy plane!!!"
msgstr "¡Avión enemigo!"

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/"
"allied_enemy_plane2"
msgid "British aircraft inbound!"
msgstr "¡Avión británico entrando en tu espacio aéreo!"

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/"
"player_enemy_near_hq"
msgid "We must hold our command post! There is no room for surrender!"
msgstr ""
"¡Debemos mantener nuestro puesto de mando! ¡No hay lugar para la rendición!"

msgctxt "mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/hq_bonus"
msgid "Major! Now you can request an artillery strike."
msgstr "¡Comandante! Ahora puedes solicitar un ataque de artillería."

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/tasks/secret01"
msgid "Secret objective #1"
msgstr "Objetivo secreto nº 1"

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/tasks/"
"secret01_completed"
msgid "Secret objective #1: Humiliating! - Captured churchill tank."
msgstr "Objetivo secreto n.º 1: ¡Humillante! - Tanque Churchill capturado."

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/tasks/secret02"
msgid "Secret objective #2"
msgstr "Objetivo secreto n.º 2"

msgctxt ""
"mission/single/051-ger_finesthour/1944_06_tilly_sur_seulles/tasks/"
"secret02_completed"
msgid ""
"Secret objective #2: Hat Trick! - Shot down three consecutive British "
"fighter planes."
msgstr ""
"Objetivo secreto n.º 2: ¡Hat Trick! - Derribaste tres aviones de combate "
"británicos consecutivos."
