msgctxt "mission/single/03-fin/1944_06_tali-ilhantala/task1"
msgid "Prepare for the enemy attack!"
msgstr "¡Prepárate para el ataque del enemigo!"

msgctxt "mission/single/03-fin/1944_06_tali-ilhantala/task2"
msgid "Hold the crossroads at all costs until the arrival of the Armoured Division."
msgstr "Manten el cruce a toda costa hasta la llegada de la División Blindada."

msgctxt "mission/single/03-fin/1944_06_tali-ilhantala/task3"
msgid "Counter-attack with the armoured reinforcements and drive the enemy off the battlefield."
msgstr "Contraataca con los refuerzos blindados y expulsa al enemigo del campo de batalla."
