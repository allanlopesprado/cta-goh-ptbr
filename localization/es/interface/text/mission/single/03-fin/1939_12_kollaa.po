msgid "37 PstK/36"
msgstr "37 PstK/36"

msgctxt "mission/single/03-fin/1939_12_kollaa/reinforcements/btn_ambush"
msgid "Begin ambush!"
msgstr "¡Que comience la emboscada!"

msgctxt ""
"mission/single/03-fin/1939_12_kollaa/reinforcements/btn_skip_preparation"
msgid "Skip preparation"
msgstr "Saltarse la preparación"

