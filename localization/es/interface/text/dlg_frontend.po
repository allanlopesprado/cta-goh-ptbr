msgctxt "main_menu2/dynamic_campaign/select_difficulty"
msgid "difficulty"
msgstr "DIFICULTAD"

msgctxt "main_menu2/dynamic_campaign/hint_difficulty"
msgid ""
"La dificultad ajusta los siguientes parámetros: \n"
"• La vida de la infantería del jugador y los aliados \n"
"• La vida de la infantería del enemigo \n"
"• Precisión de las armas del enemigo."
msgstr ""
"La dificultad ajusta los siguientes parámetros: \n"
"• La vida de la infantería del jugador y los aliados \n"
"• La vida de la infantería del enemigo \n"
"• Precisión de las armas del enemigo."

msgctxt "main_menu2/dynamic_campaign/hint_difficulty_easy"
msgid ""
"Dificultad fácil: \n"
"• Reduce en gran medida la vida de los enemigos \n"
"• Reduce en gran medida la precisión de las armas enemigas \n"
"• Reduce la probabilidad de que la infantería enemiga use granadas \n"
"• Aumenta la vida de los soldados del jugador \n"
"• Aumenta la vida de los soldados aliados."
msgstr ""
"Dificultad fácil: \n"
"• Reduce en gran medida la vida de los enemigos \n"
"• Reduce en gran medida la precisión de las armas enemigas \n"
"• Reduce la probabilidad de que la infantería enemiga use granadas \n"
"• Aumenta la vida de los soldados del jugador \n"
"• Aumenta la vida de los soldados aliados."

msgctxt "main_menu2/dynamic_campaign/hint_difficulty_normal"
msgid ""
"Dificultad intermedia: \n"
"• Reduce la vida de los enemigos \n"
"• Reduce la precisión de las armas enemigas \n"
"• Los otros parámetros son los normales"
msgstr ""
"Dificultad intermedia: \n"
"• Reduce la vida de los enemigos \n"
"• Reduce la precisión de las armas enemigas \n"
"• Los otros parámetros son los normales"

msgctxt "main_menu2/dynamic_campaign/hint_difficulty_hard"
msgid ""
"Dificultad difícil: \n"
"• Reduce la vida de los enemigos \n"
"• Reduce ligeramente la precisión de las armas enemigas \n"
"• Los otros parámetros son los normales"
msgstr ""
"Dificultad difícil: \n"
"• Reduce la vida de los enemigos \n"
"• Reduce ligeramente la precisión de las armas enemigas \n"
"• Los otros parámetros son los normales"

msgctxt "main_menu2/dynamic_campaign/hint_difficulty_heroic"
msgid ""
"Dificultad hardcore: \n"
"• Reduce ligeramente la vida de los enemigos \n"
"• Los otros parámetros son los normales"
msgstr ""
"Dificultad hardcore: \n"
"• Reduce ligeramente la vida de los enemigos \n"
"• Los otros parámetros son los normales"

