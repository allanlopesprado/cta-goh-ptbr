msgctxt "vehiclebar/terrain/forest"
msgid "Forest"
msgstr "Bosque"

msgctxt "vehiclebar/terrain/slope"
msgid "Slope"
msgstr "Pendiente"

msgctxt "actionbar/aimed_shot"
msgid "Sniper zeroed shot"
msgstr "Tiro de francotirador calibrado"

msgctxt "actionbar/aimed_shot/action"
msgid "Aims and fires the sniper rifle with maximum precision."
msgstr "Apunta y dispara el rifle francotirador con la máxima precisión."

msgctxt "actionbar/aimed_shot/usage"
msgid ""
"Click on the button, then click on an enemy unit to shoot at. The unit must "
"remain stationary for the zeroing to be completed."
msgstr ""
"Haz clic en el botón, luego haz clic en una unidad enemiga a la que "
"disparar. La unidad debe permanecer estacionaria para que se complete la "
"calibración del disparo."

msgctxt "actionbar/wirecutter"
msgid "Cut wire"
msgstr "Corta el alambre"

msgctxt "actionbar/wirecutter/action"
msgid "Break through barbed wire and wired fences."
msgstr "Rompe el alambre de púas y las cercas cableadas."

msgctxt "actionbar/wirecutter/usage"
msgid "Click on the button, then click on the object to cut."
msgstr "Haz clic en el botón, luego haz clic en el objeto a cortar."
