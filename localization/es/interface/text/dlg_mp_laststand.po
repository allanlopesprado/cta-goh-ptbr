msgctxt "mp/game/evacuation"
msgid "Last Stand"
msgstr "Última Defensa"

msgctxt "mp/game/evacuation/info"
msgid "\nDefend your HQ against waves of enemies. \nHold out until time has expired! \nSecure key locations for additional resources!"
msgstr "\n¡Defiende tu cuartel general contra oleadas \nde enemigos hasta que se acabe el tiempo!"

msgctxt "mp/game/evacuation/rules"
msgid "Last Stand"
msgstr "Última Defensa"

msgctxt "mp/game/evacuation/objective"
msgid ""
msgstr ""

msgctxt "mp/game/text/evacuation_wavetime"
msgid "The %1%. enemy wave will arrive in"
msgstr "La %1%. ola enemiga llegará en"

msgctxt "mp/game/text/evacuation_supply_secured"
msgid ""
"You have secured the designated location, HQ has sent you additional "
"resources."
msgstr ""
"Has conqistado la ubicación designada, el Cuartel General te envía recursos "
"adicionales."

msgctxt "mp/game/text/evacuation_supply_enabled"
msgid ""
"Secondary objective available! Secure the designated location for additional "
"resources!"
msgstr ""
"¡Objetivo secundario disponible! Conquista la ubicación marcada en el mapa "
"para poder obtener más recursos."

msgctxt "mp/settings/team#defenders"
msgid "Team A Defenders"
msgstr "Equipo A, Defensores"

msgctxt "mp/settings/team#attackers"
msgid "Team B Attackers"
msgstr "Equipo B, Atacantes"

msgctxt "mp/lobby/setup/settings.firstWaveTime"
msgid "Start wave time"
msgstr "Tiempo hasta la primera oleada"

msgctxt "mp/lobby/setup/settings.firstWaveTime#hint"
msgid ""
"Time in seconds between the start of the match and the first attack wave."
msgstr ""
"Tiempo (en segundos) entre el inicio de la partida y la primera oleada."

msgctxt "mp/lobby/setup/settings.waveTime"
msgid "Interval wave time"
msgstr "Tiempo de intérvalo entre oleadas"

msgctxt "mp/lobby/setup/settings.waveTime#hint"
msgid "Time in seconds between each attack wave after the first attack."
msgstr "Tiempo en segundos entre cada oleada de ataque tras la primera oleada."
