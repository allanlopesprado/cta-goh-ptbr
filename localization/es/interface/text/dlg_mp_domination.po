msgctxt "mp/game/ammunition"
msgid "Domination"
msgstr "Dominación"

msgctxt "mp/game/ammunition/rules"
msgid "Domination"
msgstr "Dominación"

msgctxt "mp/game/ammunition/objective"
msgid ""
"Destroy as many enemy targets as possible! Fortify and Protect your HQ at all costs. Lead cautious raids to apply pressure on the front line."
msgstr "¡Elimina el mayor número posible de unidades y vehículos enemigos! Y protege tu puesto avanzado a toda costa. Consigue recursos adicionales mediante ataques cautelosos en puntos clave."

msgctxt "mp/game/ammunition/info"
msgid "\nInflict as many losses to the enemy as possible. \nProtect your field HQ at all costs. \nCapture designated points to seize the initiative!"
msgstr "\n¡Elimina el mayor número posible de tropas enemigas! \nProtege tu cuartel general a toda costa. \nCaptura ubicaciones estratégicas opcionales."

msgctxt "mp/game/text/ammunition_base_won"
msgid "You have captured the enemy outpost!"
msgstr "¡Has capturado el puesto avanzado enemigo!"

msgctxt "mp/game/text/ammunition_base_lost"
msgid "The enemy has captured our outpost!"
msgstr "¡El enemigo ha capturado tu puesto avanzado!"

msgctxt "mp/game/text/ammunition_point_enabled"
msgid "High command requests to secure a strategic position!"
msgstr "¡El alto mando ha solicidado que se capture un punto estratégico marcado en el mapa!"

msgctxt "mp/game/text/ammunition_point_lost"
msgid ""
"<f(arial_hq)c(FFFFFF)s(8)>The enemy forces raided the strategic location and received additional reinforcements!"
msgstr "<f(arial_hq)c(FFFFFF)s(8)>¡Las fuerzas enemigas han capturado el objetivo estratégico y reciben refuerzos!"

msgctxt "mp/game/text/ammunition_point_won"
msgid ""
"<f(arial_hq)c(FFFFFF)s(8)>Your forces have captured the strategic position and receive additional reinforcements!"
msgstr "<f(arial_hq)c(FFFFFF)s(8)>¡Vuestras fuerzas han capturado el objetivo y recibís refuerzos!"