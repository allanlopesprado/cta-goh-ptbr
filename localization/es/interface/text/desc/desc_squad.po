msgctxt "desc/squad/squad_suppression(rus)"
msgid "Suppression Inf."
msgstr "Inf. de supresión"

msgctxt "info/squad/squad_suppression(rus)"
msgid ""
"Suppression units utilised long range automatic and semi-automatic weaponry "
"to create density of fire to support advancing troops<c(DB465A)>Tips "
"description.</c>"
msgstr "Las unidades de supresión utilizaban armas automáticas y semiautomáticas de largo alcance para crear barreras de fuego y apoyar a las tropas en maniobras de aproximación<c(DB465A)>Descripción de consejo.</c>"

