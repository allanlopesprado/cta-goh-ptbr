msgctxt "mp/game/ammunition"
msgid "Domination"
msgstr "Dominação"

msgctxt "mp/game/ammunition/rules"
msgid "Domination"
msgstr "Dominação"

msgctxt "mp/game/ammunition/objective"
msgid ""
"Destroy as many enemy targets as possible! Fortify and Protect your HQ at "
"all costs. Lead cautious raids to apply pressure on the front line."
msgstr ""
"Destrua o máximo de alvos inimigos possível! Fortifique e proteja seu QG a "
"todo custo. Conduza incursões cuidadosas para pressionar a linha de frente."

msgctxt "mp/game/ammunition/info"
msgid ""
"\nInflict as many losses to the enemy as possible. \nProtect your field HQ at all costs. \nCapture designated points to seize the initiative!"
msgstr "\nInflija o máximo de perdas possível ao inimigo. \nProteja seu QG de campo a todo custo. \nCapture os pontos designados para tomar a iniciativa!"

msgctxt "mp/game/text/ammunition_base_won"
msgid "You have captured the enemy outpost!"
msgstr "Você capturou o posto avançado inimigo!"

msgctxt "mp/game/text/ammunition_base_lost"
msgid "The enemy has captured our outpost!"
msgstr "O inimigo capturou nosso posto avançado!"

msgctxt "mp/game/text/ammunition_point_enabled"
msgid "High command requests to secure a strategic position!"
msgstr "O alto comando solicita que você assegure uma posição estratégica!"

msgctxt "mp/game/text/ammunition_point_lost"
msgid ""
"<f(arial_hq)c(FFFFFF)s(8)>The enemy forces raided the strategic location and "
"received additional reinforcements!"
msgstr "<f(arial_hq)c(FFFFFF)s(8)>As forças inimigas invadiram a posição estratégica e receberam reforços adicionais!"

msgctxt "mp/game/text/ammunition_point_won"
msgid ""
"<f(arial_hq)c(FFFFFF)s(8)>Your forces have captured the strategic position "
"and receive additional reinforcements!"
msgstr "<f(arial_hq)c(FFFFFF)s(8)>Suas forças capturaram a posição estratégica e recebem reforços adicionais!"
