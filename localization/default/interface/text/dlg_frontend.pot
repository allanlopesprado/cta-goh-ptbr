msgctxt "main_menu2/dynamic_campaign/tutorial_research_button"
msgid "Visit the <c(30bf3c)>RESEARCH TREE</c> to unlock more units."
msgstr "Acesse a <c(30bf3c)>ÁRVORE DE PESQUISA</c> para desbloquear mais unidades."

msgctxt "main_menu2/dynamic_campaign/tutorial_progress_map"
msgid "Visit the <c(30bf3c)>OPERATION MAP</c> to get some information about the next battle and choose a battlefield."
msgstr "Acesse o <c(30bf3c)>MAPA DA OPERAÇÃO</c> para obter informações sobre a próxima batalha e escolher um campo de batalha."

